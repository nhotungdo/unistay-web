@model IEnumerable<Unistay_Web.Models.Roommate.RoommateDisplayDto>
@{
    ViewData["Title"] = "Bạn ở ghép phù hợp - UniStay";
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentFilter = ViewData["CurrentFilter"] as string ?? "";
    var currentGender = ViewData["CurrentGender"] as string ?? "";
    var currentBudget = ViewData["CurrentBudget"] as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/roommates-index.css" asp-append-version="true" />
}

<!-- SVG defs for match ring gradient (hidden) -->
<svg width="0" height="0" style="position:absolute">
    <defs>
        <linearGradient id="matchGrad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" style="stop-color:#6366f1" />
            <stop offset="100%" style="stop-color:#a855f7" />
        </linearGradient>
    </defs>
</svg>

<div class="ri-page">

    <!-- Hero Search Bar -->
    <div class="ri-hero">
        <div class="ri-hero-inner">
            <h1 class="ri-hero-title">Tìm bạn ở ghép <span class="ri-hero-highlight">phù hợp</span></h1>
            <p class="ri-hero-sub">Kết nối với sinh viên FPT Hòa Lạc có cùng lối sống và ngân sách</p>
            <form method="get" asp-action="Index" class="ri-search-bar" id="filterForm">
                <div class="ri-search-input-wrap">
                    <i class="fas fa-search"></i>
                    <input type="text" name="searchString" value="@currentFilter" placeholder="Tìm theo khu vực, tên..." class="ri-search-input" />
                </div>
                <select name="gender" class="ri-select" onchange="this.form.submit()">
                    <!option value="">Giới tính</!option>
                    <!option value="Male" selected="@(currentGender == "Male" ? "selected" : null)">Nam</!option>
                    <!option value="Female" selected="@(currentGender == "Female" ? "selected" : null)">Nữ</!option>
                    <!option value="Other" selected="@(currentGender == "Other" ? "selected" : null)">Khác</!option>
                </select>
                <select name="budgetRange" class="ri-select" onchange="this.form.submit()">
                    <!option value="">Ngân sách</!option>
                    <!option value="low" selected="@(currentBudget == "low" ? "selected" : null)">Dưới 2 triệu</!option>
                    <!option value="medium" selected="@(currentBudget == "medium" ? "selected" : null)">2 - 4 triệu</!option>
                    <!option value="high" selected="@(currentBudget == "high" ? "selected" : null)">Trên 4 triệu</!option>
                </select>
                <button type="submit" class="ri-btn-search">
                    <i class="fas fa-search"></i> Tìm kiếm
                </button>
                @if (!string.IsNullOrEmpty(currentFilter) || !string.IsNullOrEmpty(currentGender) || !string.IsNullOrEmpty(currentBudget))
                {
                    <a asp-action="Index" class="ri-btn-clear" title="Xóa bộ lọc">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </form>
        </div>
    </div>

    <!-- Active Filters -->
    @if (!string.IsNullOrEmpty(currentFilter) || !string.IsNullOrEmpty(currentGender) || !string.IsNullOrEmpty(currentBudget))
    {
        <div class="ri-active-filters">
            <span class="ri-filter-label"><i class="fas fa-filter"></i> Đang lọc:</span>
            @if (!string.IsNullOrEmpty(currentFilter))
            {
                <span class="ri-filter-chip">Khu vực: @currentFilter <a asp-action="Index" asp-route-gender="@currentGender" asp-route-budgetRange="@currentBudget"><i class="fas fa-times"></i></a></span>
            }
            @if (!string.IsNullOrEmpty(currentGender))
            {
                var genderLabel = currentGender == "Male" ? "Nam" : currentGender == "Female" ? "Nữ" : "Khác";
                <span class="ri-filter-chip">Giới tính: @genderLabel <a asp-action="Index" asp-route-searchString="@currentFilter" asp-route-budgetRange="@currentBudget"><i class="fas fa-times"></i></a></span>
            }
            @if (!string.IsNullOrEmpty(currentBudget))
            {
                var budgetLabel = currentBudget == "low" ? "Dưới 2tr" : currentBudget == "medium" ? "2-4tr" : "Trên 4tr";
                <span class="ri-filter-chip">Ngân sách: @budgetLabel <a asp-action="Index" asp-route-searchString="@currentFilter" asp-route-gender="@currentGender"><i class="fas fa-times"></i></a></span>
            }
        </div>
    }

    <!-- Main Layout -->
    <div class="ri-layout">
        <!-- Sidebar -->
        <aside class="ri-sidebar">
            <div class="ri-sidebar-card">
                <div class="ri-sidebar-title"><i class="fas fa-sliders-h"></i> Bộ lọc nhanh</div>

                <form method="get" asp-action="Index" id="sidebarForm">
                    <input type="hidden" name="searchString" value="@currentFilter" />

                    <div class="ri-filter-group">
                        <div class="ri-filter-group-label">Giới tính</div>
                        <label class="ri-radio-item @(currentGender == "" ? "active" : "")">
                            <input type="radio" name="gender" value="" @(currentGender == "" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> Tất cả
                        </label>
                        <label class="ri-radio-item @(currentGender == "Male" ? "active" : "")">
                            <input type="radio" name="gender" value="Male" @(currentGender == "Male" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> <i class="fas fa-mars text-primary"></i> Nam
                        </label>
                        <label class="ri-radio-item @(currentGender == "Female" ? "active" : "")">
                            <input type="radio" name="gender" value="Female" @(currentGender == "Female" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> <i class="fas fa-venus text-danger"></i> Nữ
                        </label>
                    </div>

                    <div class="ri-filter-group">
                        <div class="ri-filter-group-label">Ngân sách</div>
                        <label class="ri-radio-item @(currentBudget == "" ? "active" : "")">
                            <input type="radio" name="budgetRange" value="" @(currentBudget == "" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> Tất cả
                        </label>
                        <label class="ri-radio-item @(currentBudget == "low" ? "active" : "")">
                            <input type="radio" name="budgetRange" value="low" @(currentBudget == "low" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> Dưới 2 triệu
                        </label>
                        <label class="ri-radio-item @(currentBudget == "medium" ? "active" : "")">
                            <input type="radio" name="budgetRange" value="medium" @(currentBudget == "medium" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> 2 - 4 triệu
                        </label>
                        <label class="ri-radio-item @(currentBudget == "high" ? "active" : "")">
                            <input type="radio" name="budgetRange" value="high" @(currentBudget == "high" ? "checked" : "") onchange="document.getElementById('sidebarForm').submit()"> Trên 4 triệu
                        </label>
                    </div>
                </form>
            </div>

            <!-- Tip Box -->
            <div class="ri-tip-box">
                <div class="ri-tip-icon"><i class="fas fa-lightbulb"></i></div>
                <div class="ri-tip-title">Mẹo tìm bạn</div>
                <p class="ri-tip-text">Điền đầy đủ thông tin thói quen sinh hoạt để AI tìm được người bạn cùng phòng lý tưởng nhất tại Hòa Lạc.</p>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Roommates" asp-action="Match" class="ri-tip-btn">
                        <i class="fas fa-magic"></i> Thử AI Match
                    </a>
                }
            </div>
        </aside>

        <!-- Main Content -->
        <main class="ri-main">
            <div class="ri-results-header">
                <div>
                    <div class="ri-results-title">Bạn ở ghép phù hợp</div>
                    <div class="ri-results-count">
                        Tìm thấy <strong>@Model.Count()</strong> sinh viên đang tìm người ở cùng
                        @if (!string.IsNullOrEmpty(currentFilter)) { <span>tại <strong>@currentFilter</strong></span> }
                    </div>
                </div>
                <div class="ri-sort-row">
                    <a asp-action="Index" asp-route-searchString="@currentFilter" asp-route-gender="@currentGender" asp-route-budgetRange="@currentBudget" asp-route-sort="newest"
                       class="ri-sort-btn @(ViewData["CurrentSort"] as string != "budget" ? "active" : "")">Mới nhất</a>
                    <a asp-action="Index" asp-route-searchString="@currentFilter" asp-route-gender="@currentGender" asp-route-budgetRange="@currentBudget" asp-route-sort="budget"
                       class="ri-sort-btn @(ViewData["CurrentSort"] as string == "budget" ? "active" : "")">Giá thấp - cao</a>
                </div>
            </div>

            @if (!Model.Any())
            {
                <div class="ri-empty">
                    <div class="ri-empty-icon"><i class="fas fa-user-friends"></i></div>
                    <h3>Không tìm thấy kết quả</h3>
                    <p>Thử thay đổi bộ lọc hoặc tìm kiếm với từ khóa khác.</p>
                    <a asp-action="Index" class="ri-btn-create">Xem tất cả</a>
                </div>
            }
            else
            {
                <div class="ri-card-grid">
                    @foreach (var item in Model)
                    {
                        <div class="ri-card">
                            <div class="ri-card-media">
                                @if (item.MatchPercentage >= 90)
                                {
                                    <span class="ri-badge-top"><i class="fas fa-crown"></i> Top Match</span>
                                }
                                <img src="@(!string.IsNullOrEmpty(item.AvatarUrl) ? item.AvatarUrl : "/images/default-avatar.png")"
                                     alt="@item.FullName"
                                     onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.FullName)&background=6366f1&color=fff&size=200'" />
                                <div class="ri-card-overlay">
                                    <div class="ri-match-ring" data-score="@item.MatchPercentage">
                                        <svg viewBox="0 0 36 36">
                                            <path class="ri-ring-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                            <path class="ri-ring-fill" stroke-dasharray="@item.MatchPercentage, 100"
                                                  d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                        </svg>
                                        <span class="ri-ring-text">@item.MatchPercentage%</span>
                                    </div>
                                </div>
                                <div class="ri-budget-bar">
                                    <span class="ri-budget-label">Ngân sách</span>
                                    <span class="ri-budget-val">@(item.Budget > 0 ? (item.Budget / 1000000m).ToString("N1") + "tr" : "Thỏa thuận")/tháng</span>
                                </div>
                            </div>

                            <div class="ri-card-body">
                                <div class="ri-card-top">
                                    <div>
                                        <div class="ri-card-name">@item.FullName@(item.Age > 0 ? $", {item.Age}" : "")</div>
                                        <div class="ri-card-loc"><i class="fas fa-map-marker-alt"></i> @(item.PreferredArea ?? "Hòa Lạc")</div>
                                    </div>
                                    <button class="ri-btn-heart" onclick="toggleFavorite(this, @item.Id)" title="Lưu hồ sơ">
                                        <i class="far fa-heart"></i>
                                    </button>
                                </div>

                                <div class="ri-card-tags">
                                    @if (!string.IsNullOrEmpty(item.Gender))
                                    {
                                        <span class="ri-tag ri-tag-gender">
                                            <i class="fas @(item.Gender == "Male" ? "fa-mars" : item.Gender == "Female" ? "fa-venus" : "fa-genderless")"></i>
                                            @(item.Gender == "Male" ? "Nam" : item.Gender == "Female" ? "Nữ" : "Khác")
                                        </span>
                                    }
                                    @if (!string.IsNullOrEmpty(item.Occupation))
                                    {
                                        <span class="ri-tag ri-tag-occ"><i class="fas fa-graduation-cap"></i> @item.Occupation</span>
                                    }
                                </div>

                                @if (item.Habits.Any())
                                {
                                    <div class="ri-habits">
                                        @foreach (var h in item.Habits.Take(3))
                                        {
                                            <span class="ri-habit-tag">@h</span>
                                        }
                                        @if (item.Habits.Length > 3)
                                        {
                                            <span class="ri-habit-more">+@(item.Habits.Length - 3)</span>
                                        }
                                    </div>
                                }

                                <div class="ri-card-footer">
                                    <span class="ri-posted-time"><i class="far fa-clock"></i> @GetTimeAgo(item.CreatedAt)</span>
                                    <a asp-action="Profile" asp-route-id="@item.Id" class="ri-btn-view">Xem chi tiết <i class="fas fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="ri-load-more">
                    <button class="ri-btn-more" onclick="loadMore(this)">
                        <i class="fas fa-chevron-down"></i> Xem thêm sinh viên
                    </button>
                </div>
            }
        </main>
    </div>
</div>

@functions {
    string GetTimeAgo(DateTime dt)
    {
        var diff = DateTime.Now - dt;
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} phút trước";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} giờ trước";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays} ngày trước";
        return dt.ToString("dd/MM/yyyy");
    }
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Animate cards on scroll
            const cards = document.querySelectorAll('.ri-card');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry, i) => {
                    if (entry.isIntersecting) {
                        setTimeout(() => entry.target.classList.add('ri-card-visible'), i * 60);
                        observer.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1 });
            cards.forEach(c => observer.observe(c));
        });

        function toggleFavorite(btn, id) {
            const icon = btn.querySelector('i');
            icon.classList.toggle('far');
            icon.classList.toggle('fas');
            btn.classList.toggle('ri-btn-heart-active');
        }

        function loadMore(btn) {
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang tải...';
            btn.disabled = true;
            // Placeholder - would call API in real implementation
            setTimeout(() => {
                btn.innerHTML = '<i class="fas fa-check"></i> Đã hiển thị tất cả';
            }, 1200);
        }
    </script>
}
