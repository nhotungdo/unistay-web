@model Unistay_Web.Models.Roommate.RoommateProfileDetailViewModel
@{
    ViewData["Title"] = "Hồ sơ: " + Model.FullName;
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";

    var genderDisplay = Model.Gender == "Male" ? "Nam" : Model.Gender == "Female" ? "Nữ" : (Model.Gender ?? "Nam");
    var budgetDisplay = Model.Budget > 0 ? (Model.Budget / 1000000m).ToString("N1") + "tr" : "1.5tr";
}

@section Styles {
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
}

<div class="pf-page">


    <!-- ===== MAIN GRID ===== -->
    <div class="pf-container">
        <div class="pf-grid">

            <!-- LEFT SIDEBAR -->
            <aside class="pf-sidebar-left">
                <div class="pf-filter-card">
                    <div class="pf-filter-title">Bộ lọc tìm kiếm</div>
                    <div class="pf-filter-sub">Hòa Lạc, Thạch Thất</div>

                    <a asp-controller="Roommates" asp-action="Index" asp-route-searchString="" class="pf-filter-item active">
                        <i class="fas fa-map-marker-alt"></i> Khu vực
                    </a>
                    <a asp-controller="Roommates" asp-action="Index" asp-route-budgetRange="medium" class="pf-filter-item">
                        <i class="fas fa-wallet"></i> Ngân sách
                    </a>
                    <div class="pf-filter-item">
                        <i class="fas fa-compass"></i> Cung hoàng đạo
                    </div>
                    <div class="pf-filter-item">
                        <i class="fas fa-heart"></i> Sở thích
                    </div>
                    <div class="pf-filter-item">
                        <i class="fas fa-user-friends"></i> Giới tính
                    </div>

                    <a asp-controller="Roommates" asp-action="Index" class="pf-btn-apply">Áp dụng bộ lọc</a>
                </div>
            </aside>

            <!-- MAIN CONTENT -->
            <main class="pf-main">

                <!-- HERO CARD -->
                <div class="pf-hero-card">
                    <div class="pf-hero-avatar">
                        <img src="@(!string.IsNullOrEmpty(Model.AvatarUrl) ? Model.AvatarUrl : "/images/default-avatar.png")"
                             alt="@Model.FullName"
                             onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.FullName)&background=6366f1&color=fff&size=200'" />
                    </div>
                    <div class="pf-hero-info">
                        <div class="pf-hero-badges">
                            <span class="pf-badge pf-badge-green">SV FPT</span>
                            <span class="pf-badge pf-badge-yellow">PREMIUM MEMBER</span>
                        </div>
                        <h1 class="pf-hero-name">@Model.FullName</h1>
                        <div class="pf-hero-meta">
                            <span><i class="fas fa-user"></i> @genderDisplay</span>
                            <span><i class="fas fa-graduation-cap"></i> @(Model.Occupation ?? "Kỹ thuật phần mềm")</span>
                        </div>
                        <div class="pf-hero-actions">
                            @if (Model.ConnectionState == "accepted")
                            {
                                <a asp-controller="Messages" asp-action="Index" class="pf-btn-chat">
                                    <i class="fas fa-comment-alt"></i> Nhắn tin ngay
                                </a>
                            }
                            else if (Model.ConnectionState == "pending_sent")
                            {
                                <button class="pf-btn-chat pf-btn-pending" disabled>
                                    <i class="fas fa-clock"></i> Đã gửi lời mời
                                </button>
                            }
                            else if (Model.ConnectionState == "self")
                            {
                                <a asp-controller="Roommates" asp-action="Create" class="pf-btn-chat">
                                    <i class="fas fa-edit"></i> Chỉnh sửa hồ sơ
                                </a>
                            }
                            else
                            {
                                <form asp-controller="Connections" asp-action="SendRequest" method="post" style="display:inline">
                                    <input type="hidden" name="addresseeId" value="@Model.UserId" />
                                    <button type="submit" class="pf-btn-chat">
                                        <i class="fas fa-comment-alt"></i> Nhắn tin ngay
                                    </button>
                                </form>
                            }
                            <button class="pf-btn-save" title="Lưu hồ sơ">
                                <i class="fas fa-bookmark"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <!-- CRITERIA + REQUIREMENTS ROW -->
                <div class="pf-two-col">
                    <!-- Tiêu chí tìm bạn -->
                    <div class="pf-section-card">
                        <div class="pf-section-header">
                            <span class="pf-section-line pf-line-blue"></span>
                            <h2 class="pf-section-title">Tiêu chí tìm bạn</h2>
                        </div>

                        <div class="pf-info-row">
                            <div class="pf-info-icon pf-icon-blue"><i class="fas fa-money-bill-wave"></i></div>
                            <div class="pf-info-body">
                                <div class="pf-info-label">Ngân sách mong muốn</div>
                                <div class="pf-info-val">@budgetDisplay – 2.5tr <span class="pf-info-unit">/tháng</span></div>
                            </div>
                            <i class="fas fa-chevron-right pf-info-arrow"></i>
                        </div>

                        <div class="pf-info-row" style="margin-top:12px">
                            <div class="pf-info-icon pf-icon-blue"><i class="fas fa-map-marker-alt"></i></div>
                            <div class="pf-info-body">
                                <div class="pf-info-label">Khu vực ưu tiên</div>
                                <div class="pf-info-val">@(Model.PreferredArea ?? "Tân Xã, Thạch Hòa")</div>
                            </div>
                        </div>

                        <!-- Map mock -->
                        <div class="pf-map-wrap">
                            <img src="https://images.unsplash.com/photo-1524661135-423995f22d0b?w=600&q=80" alt="map" />
                            <div class="pf-map-pin"><i class="fas fa-map-marker-alt"></i> Khu vực ưu tiên</div>
                        </div>
                        <p class="pf-map-note"><i class="fas fa-info-circle"></i> Khu vực được tô màu xanh là nơi @Model.FullName đang muốn tìm phòng nhất.</p>
                    </div>

                    <!-- Yêu cầu thêm -->
                    <div class="pf-section-card">
                        <div class="pf-section-header">
                            <span class="pf-section-line pf-line-blue"></span>
                            <h2 class="pf-section-title">Yêu cầu thêm</h2>
                        </div>
                        <div class="pf-req-list">
                            <div class="pf-req-item">
                                <div class="pf-req-icon pf-icon-blue"><i class="fas fa-broom"></i></div>
                                <div>
                                    <div class="pf-req-title">Sạch sẽ & Ngăn nắp</div>
                                    <div class="pf-req-desc">Mong muốn tìm người bạn có ý thức giữ gìn vệ sinh không gian chung, dọn dẹp phòng định kỳ.</div>
                                </div>
                            </div>
                            <div class="pf-req-item">
                                <div class="pf-req-icon pf-icon-red"><i class="fas fa-smoking-ban"></i></div>
                                <div>
                                    <div class="pf-req-title">Không hút thuốc</div>
                                    <div class="pf-req-desc">Ưu tiên những bạn không hút thuốc lá hoặc thuốc lá điện tử để đảm bảo không khí trong phòng.</div>
                                </div>
                            </div>
                            <div class="pf-req-item">
                                <div class="pf-req-icon pf-icon-green"><i class="fas fa-clock"></i></div>
                                <div>
                                    <div class="pf-req-title">Giờ giấc tự do</div>
                                    <div class="pf-req-desc">Tôn trọng không gian riêng tư và giờ giấc sinh hoạt của nhau, không giới hạn giờ về.</div>
                                </div>
                            </div>
                            <div class="pf-req-item">
                                <div class="pf-req-icon pf-icon-orange"><i class="fas fa-paw"></i></div>
                                <div>
                                    <div class="pf-req-title">Không nuôi thú cưng</div>
                                    <div class="pf-req-desc">Để duy trì vệ sinh và tránh dị ứng, vui lòng không mang theo vật nuôi vào phòng.</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- REVIEWS: CHỦ TRỌ -->
                <div class="pf-section-card pf-full-width">
                    <div class="pf-section-header">
                        <span class="pf-section-line pf-line-green"></span>
                        <h2 class="pf-section-title">Đánh giá từ chủ trọ cũ</h2>
                        <a href="#" class="pf-section-link"><i class="fas fa-map-marked-alt"></i> Xem bản đồ khu vực</a>
                    </div>
                    <div class="pf-reviews-grid">
                        <div class="pf-review-card">
                            <div class="pf-rev-top">
                                <span class="pf-rev-name">Chú Hoàng</span>
                                <span class="pf-rev-stars">★★★★★</span>
                            </div>
                            <div class="pf-rev-role">Chủ nhà tại Thạch Hòa</div>
                            <p class="pf-rev-text">"Quân là một người thuê nhà rất có trách nhiệm. Cậu ấy luôn đóng tiền phòng đúng hạn và giữ gìn phòng ốc rất sạch sẽ. Rất lịch sự với mọi người xung quanh."</p>
                        </div>
                        <div class="pf-review-card">
                            <div class="pf-rev-top">
                                <span class="pf-rev-name">Cô Lan</span>
                                <span class="pf-rev-stars">★★★★★</span>
                            </div>
                            <div class="pf-rev-role">Chủ nhà tại Tân Xã</div>
                            <p class="pf-rev-text">"Sinh viên rất ngoan, không bao giờ gây ồn ào hay làm phiền hàng xóm. Khi chuyển đi, phòng được dọn dẹp rất ngăn nắp. Tôi rất tin tưởng khi cho Quân thuê."</p>
                        </div>
                    </div>
                </div>

                <!-- REVIEWS: BẠN BÈ -->
                <div class="pf-section-card pf-full-width">
                    <div class="pf-section-header">
                        <span class="pf-section-line pf-line-green"></span>
                        <h2 class="pf-section-title">Đánh giá từ bạn bè</h2>
                    </div>
                    <div class="pf-reviews-grid">
                        <div class="pf-review-card">
                            <div class="pf-rev-top">
                                <span class="pf-rev-name">Lê Văn Nam</span>
                                <span class="pf-rev-stars">★★★★★</span>
                            </div>
                            <div class="pf-rev-role">Bạn cùng lớp</div>
                            <p class="pf-rev-text">"Quân là một người rất điềm đạm, ngăn nắp và cực kỳ có trách nhiệm. Chắc chắn sẽ là một người bạn cùng phòng lý tưởng."</p>
                        </div>
                        <div class="pf-review-card">
                            <div class="pf-rev-top">
                                <span class="pf-rev-name">Trần Thu Hà</span>
                                <span class="pf-rev-stars">★★★★★</span>
                            </div>
                            <div class="pf-rev-role">Bạn thân</div>
                            <p class="pf-rev-text">"Biết Quân từ hồi năm nhất, Quân rất tôn trọng không gian riêng của người khác và luôn sẵn sàng giúp đỡ bạn bè."</p>
                        </div>
                    </div>
                </div>

                <!-- LỊCH SỬ THUÊ TRỌ -->
                <div class="pf-section-card pf-full-width pf-section-gray">
                    <div class="pf-section-header">
                        <span class="pf-section-line pf-line-blue"></span>
                        <h2 class="pf-section-title">Lịch sử thuê trọ</h2>
                    </div>
                    <div class="pf-history-grid">
                        <div class="pf-hist-card">
                            <div class="pf-hist-top">
                                <div class="pf-hist-icon"><i class="fas fa-building"></i></div>
                                <div class="pf-hist-meta">
                                    <div class="pf-hist-name">Khu trọ Thạch Hòa</div>
                                    <div class="pf-hist-date"><i class="far fa-clock"></i> 12 tháng (2023)</div>
                                </div>
                                <span class="pf-hist-badge">ĐÃ HOÀN THÀNH</span>
                            </div>
                            <p class="pf-hist-quote">"Môi trường yên tĩnh, gần trường, chủ nhà hỗ trợ nhiệt tình."</p>
                            <div class="pf-hist-reply">
                                <div class="pf-hist-reply-label">PHẢN HỒI CỦA TÔI</div>
                                <div class="pf-hist-stars">★★★★★ <span>(5.0/5.0)</span></div>
                                <p>"Cảm ơn chú Hoàng vì sự hỗ trợ nhiệt tình trong suốt 1 năm qua!"</p>
                            </div>
                        </div>
                        <div class="pf-hist-card">
                            <div class="pf-hist-top">
                                <div class="pf-hist-icon"><i class="fas fa-home"></i></div>
                                <div class="pf-hist-meta">
                                    <div class="pf-hist-name">Chung cư mini Tân Xã</div>
                                    <div class="pf-hist-date"><i class="far fa-clock"></i> 6 tháng (2022)</div>
                                </div>
                                <span class="pf-hist-badge">ĐÃ HOÀN THÀNH</span>
                            </div>
                            <p class="pf-hist-quote">"Tiện nghi đầy đủ, an ninh tốt, chuyển đi do muốn tìm phòng gần bạn bè hơn."</p>
                            <div class="pf-hist-reply">
                                <div class="pf-hist-reply-label">PHẢN HỒI CỦA TÔI</div>
                                <div class="pf-hist-stars">★★★★★ <span>(4.8/5.0)</span></div>
                                <p>"Phòng ốc rất mới và hiện đại, bảo vệ thân thiện."</p>
                            </div>
                        </div>
                    </div>
                </div>

            </main>

            <!-- RIGHT SIDEBAR -->
            <aside class="pf-sidebar-right">
                <!-- Zodiac -->
                <div class="pf-side-card">
                    <div class="pf-side-header">
                        <span class="pf-side-title">CUNG HOÀNG ĐẠO</span>
                        <i class="fas fa-star" style="color:#f59e0b; font-size:14px;"></i>
                    </div>
                    <div class="pf-zodiac-row">
                        <div class="pf-zodiac-icon"><i class="fas fa-sun"></i></div>
                        <div>
                            <div class="pf-zodiac-name">Sư Tử</div>
                            <div class="pf-zodiac-desc">Quyết đoán & Nhiệt huyết</div>
                        </div>
                    </div>
                </div>

                <!-- Interests -->
                <div class="pf-side-card">
                    <div class="pf-side-header">
                        <span class="pf-side-title">SỞ THÍCH CÁ NHÂN</span>
                    </div>
                    <div class="pf-interests">
                        @if (Model.Habits.Any())
                        {
                            foreach (var h in Model.Habits)
                            {
                                <span class="pf-interest-tag">@h</span>
                            }
                        }
                        else
                        {
                            <span class="pf-interest-tag">Chơi game</span>
                            <span class="pf-interest-tag">Nấu ăn</span>
                            <span class="pf-interest-tag">Gym</span>
                        }
                    </div>
                </div>

                <!-- AI Score (if available) -->
                @if (Model.CompatibilityScore > 0)
                {
                    <div class="pf-side-card">
                        <div class="pf-side-header">
                            <span class="pf-side-title">ĐỘ TƯƠNG HỢP AI</span>
                            <i class="fas fa-magic" style="color:#6366f1; font-size:14px;"></i>
                        </div>
                        <div class="pf-score-circle">
                            <svg viewBox="0 0 36 36">
                                <path class="pf-ring-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                                <path class="pf-ring-fill" stroke-dasharray="@Model.CompatibilityScore, 100"
                                      d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" />
                            </svg>
                            <span class="pf-score-text">@Model.CompatibilityScore%</span>
                        </div>
                        @if (!string.IsNullOrEmpty(Model.AiAnalysisReport))
                        {
                            <p class="pf-ai-report">@Model.AiAnalysisReport</p>
                        }
                    </div>
                }
            </aside>

        </div>
    </div>

    <!-- FOOTER -->
    <footer class="pf-footer">
        <div class="pf-footer-inner">
            <div>
                <div class="pf-footer-brand">Tìm Ở Ghép FPT</div>
                <p>Nền tảng kết nối sinh viên FPT Hòa Lạc tìm kiếm người ở ghép phù hợp và tin cậy.</p>
            </div>
            <div>
                <div class="pf-footer-heading">Về chúng tôi</div>
                <a href="#">Câu chuyện thương hiệu</a>
                <a href="#">Đội ngũ phát triển</a>
            </div>
            <div>
                <div class="pf-footer-heading">Điều khoản sử dụng</div>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Quy định cộng đồng</a>
            </div>
            <div>
                <div class="pf-footer-heading">Liên hệ hỗ trợ</div>
                <span><i class="fas fa-envelope"></i> support@@fptroom.vn</span>
                <span><i class="fas fa-phone-alt"></i> 1900 1234</span>
            </div>
        </div>
        <div class="pf-footer-bottom">
            <span>© 2024 Cộng đồng Sinh viên FPT Hòa Lạc</span>
            <span>Trải nghiệm người dùng được ưu tiên hàng đầu</span>
        </div>
    </footer>

</div>

@section Scripts {
}
