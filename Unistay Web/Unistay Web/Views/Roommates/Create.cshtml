@model Unistay_Web.Models.Roommate.RoommateProfile
@{
    ViewData["Title"] = "Đăng tin mới - UniStay";
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var isEdit = Model?.Id > 0;
}

@section Styles {
    <link rel="stylesheet" href="~/css/create-post.css" asp-append-version="true" />
}

<div class="cp-page">

    <!-- ===== BODY ===== -->
    <div class="cp-body">
        <div class="cp-container">

            <!-- Page heading -->
            <div class="cp-heading">
                <div class="cp-step-label">BƯỚC ĐẦU TÌM TỔ ẤM</div>
                <h1 class="cp-title">Đăng tin mới</h1>
                <p class="cp-subtitle">Chia sẻ nhu cầu của bạn để tìm được căn phòng ưng ý hoặc những người bạn đồng hành tuyệt vời nhất.</p>
            </div>

            <div class="cp-layout">
                <!-- LEFT: Form -->
                <div class="cp-form-col">

                    <!-- Post type selector -->
                    <div class="cp-type-selector">
                        <label class="cp-type-card @(Model?.Id == 0 || Model == null ? "cp-type-active" : "")" id="typeRoom">
                            <input type="radio" name="postType" value="room" checked />
                            <div class="cp-type-icon"><i class="fas fa-search"></i></div>
                            <div class="cp-type-info">
                                <div class="cp-type-title">Đăng tin tìm phòng</div>
                                <div class="cp-type-desc">Bạn đang tìm một nơi không gian sống riêng tư hoặc chia sẻ.</div>
                            </div>
                        </label>
                        <label class="cp-type-card" id="typeRoommate">
                            <input type="radio" name="postType" value="roommate" />
                            <div class="cp-type-icon cp-type-icon-green"><i class="fas fa-user-friends"></i></div>
                            <div class="cp-type-info">
                                <div class="cp-type-title">Đăng tin tìm bạn ở ghép</div>
                                <div class="cp-type-desc">Bạn có phòng và đang tìm người chia sẻ chi phí.</div>
                            </div>
                        </label>
                    </div>

                    <!-- Main form card -->
                    <div class="cp-form-card">
                        <div class="cp-form-section-title">
                            <span class="cp-form-section-bar"></span> Thông tin cơ bản
                        </div>

                        <form asp-action="Create" method="post" enctype="multipart/form-data" id="mainForm">
                            @Html.AntiForgeryToken()

                            <!-- Title -->
                            <div class="cp-field">
                                <label class="cp-label">Tiêu đề bài viết</label>
                                <input type="text" name="FullName" value="@ViewBag.UserFullName"
                                       class="cp-input" placeholder="VD: Tìm phòng trọ khu vực Bách Khoa, đầy đủ tiện nghi" />
                            </div>

                            <!-- Description -->
                            <div class="cp-field">
                                <label class="cp-label">Nội dung chi tiết</label>
                                <textarea name="Introduction" class="cp-textarea"
                                          placeholder="Mô tả kỹ hơn về mong muốn của bạn: diện tích, tiện ích, thói quen sinh hoạt...">@ViewBag.UserBio</textarea>
                            </div>

                            <!-- Area + Budget row -->
                            <div class="cp-row-2">
                                <div class="cp-field">
                                    <label class="cp-label">Khu vực mong muốn</label>
                                    <div class="cp-input-icon-wrap">
                                        <i class="fas fa-map-marker-alt cp-input-icon"></i>
                                        <input type="text" asp-for="PreferredArea" class="cp-input cp-input-padded"
                                               placeholder="Quận, Phường hoặc Tên trường" />
                                    </div>
                                </div>
                                <div class="cp-field">
                                    <label class="cp-label">Ngân sách dự kiến (VNĐ/tháng)</label>
                                    <div class="cp-input-icon-wrap">
                                        <i class="fas fa-wallet cp-input-icon"></i>
                                        <input type="number" asp-for="Budget" class="cp-input cp-input-padded"
                                               placeholder="VD: 3000000" />
                                    </div>
                                </div>
                            </div>

                            <!-- Hidden fields -->
                            <input type="hidden" asp-for="Gender" id="genderHidden" value="@(Model?.Gender ?? "Male")" />
                            <input type="hidden" asp-for="MoveInDate" id="moveInHidden" />
                            <input type="hidden" asp-for="Habits" id="HabitsInput" />

                            <!-- Gender + Move-in row -->
                            <div class="cp-row-2">
                                <div class="cp-field">
                                    <label class="cp-label">Giới tính</label>
                                    <div class="cp-gender-row">
                                        <label class="cp-gender-opt @(Model?.Gender == "Male" || Model?.Gender == null ? "active" : "")">
                                            <input type="radio" name="genderSelect" value="Male" @(Model?.Gender != "Female" && Model?.Gender != "Other" ? "checked" : "") />
                                            <i class="fas fa-mars"></i> Nam
                                        </label>
                                        <label class="cp-gender-opt @(Model?.Gender == "Female" ? "active" : "")">
                                            <input type="radio" name="genderSelect" value="Female" @(Model?.Gender == "Female" ? "checked" : "") />
                                            <i class="fas fa-venus"></i> Nữ
                                        </label>
                                        <label class="cp-gender-opt @(Model?.Gender == "Other" ? "active" : "")">
                                            <input type="radio" name="genderSelect" value="Other" @(Model?.Gender == "Other" ? "checked" : "") />
                                            <i class="fas fa-genderless"></i> Khác
                                        </label>
                                    </div>
                                </div>
                                <div class="cp-field">
                                    <label class="cp-label">Ngày dự kiến chuyển vào</label>
                                    <div class="cp-input-icon-wrap">
                                        <i class="fas fa-calendar-alt cp-input-icon"></i>
                                        <input type="date" name="moveInDatePicker" class="cp-input cp-input-padded"
                                               value="@(Model?.MoveInDate?.ToString("yyyy-MM-dd") ?? "")" />
                                    </div>
                                </div>
                            </div>

                            <!-- Habits -->
                            <div class="cp-field">
                                <label class="cp-label">Thói quen & Lối sống</label>
                                <div class="cp-habits-wrap">
                                    @{
                                        var allHabits = new[] { "Không hút thuốc", "Gọn gàng", "Yên tĩnh", "Thích nấu ăn", "Thân thiện", "Thích thú cưng", "Ngủ sớm", "Tiệc tùng" };
                                        var currentHabits = Model?.Habits?.Split(new[] { ',', ' ' }, StringSplitOptions.RemoveEmptyEntries) ?? Array.Empty<string>();
                                    }
                                    @foreach (var habit in allHabits)
                                    {
                                        var isChecked = currentHabits.Contains(habit);
                                        <label class="cp-habit-chip @(isChecked ? "active" : "")">
                                            <input type="checkbox" name="HabitsList" value="@habit" @(isChecked ? "checked" : "") />
                                            @habit
                                        </label>
                                    }
                                </div>
                            </div>

                            <!-- Image upload -->
                            <div class="cp-field">
                                <label class="cp-label">Hình ảnh minh họa</label>
                                <label class="cp-upload-zone" for="avatarUpload" id="uploadZone">
                                    <div class="cp-upload-inner" id="uploadPlaceholder">
                                        <div class="cp-upload-icon"><i class="fas fa-image"></i></div>
                                        <div class="cp-upload-text">Tải ảnh lên hoặc kéo thả vào đây</div>
                                        <div class="cp-upload-hint">Hỗ trợ JPG, PNG (Tối đa 5 ảnh, mỗi ảnh < 5MB)</div>
                                    </div>
                                </label>
                                <input type="file" id="avatarUpload" name="avatarUpload" class="cp-file-input" accept="image/*" />

                                <!-- Preview thumbnails -->
                                <div class="cp-preview-row" id="previewRow">
                                    @if (!string.IsNullOrEmpty(ViewBag.UserAvatar as string))
                                    {
                                        <div class="cp-thumb">
                                            <img src="@ViewBag.UserAvatar" alt="preview" />
                                            <button type="button" class="cp-thumb-remove"><i class="fas fa-times"></i></button>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Occupation (hidden, sent to controller) -->
                            <input type="hidden" name="Occupation" value="@ViewBag.UserOccupation" />
                            <input type="hidden" name="BirthYear" value="@ViewBag.UserBirthYear" />

                            <!-- Actions -->
                            <div class="cp-form-actions">
                                <button type="button" class="cp-btn-draft" onclick="saveDraft()">
                                    <i class="fas fa-save"></i> Lưu nháp
                                </button>
                                <button type="submit" class="cp-btn-submit">
                                    <i class="fas fa-check-circle"></i> Xác nhận Đăng tin
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- RIGHT: Sidebar -->
                <aside class="cp-sidebar">
                    <!-- Tips -->
                    <div class="cp-tip-card">
                        <div class="cp-tip-header">
                            <div class="cp-tip-icon"><i class="fas fa-lightbulb"></i></div>
                            <span class="cp-tip-title">Mẹo đăng tin hiệu quả</span>
                        </div>
                        <ol class="cp-tip-list">
                            <li>Tiêu đề rõ ràng bao gồm khu vực và mục đích chính giúp tin của bạn dễ được tìm thấy hơn.</li>
                            <li>Cung cấp ít nhất 3 ảnh thật về không gian sống hiện tại (nếu tìm ở ghép) để tăng độ tin cậy.</li>
                            <li>Nêu rõ các quy tắc chung như giờ giấc, hút thuốc, hay thú cưng để lọc đối tác tương xứng.</li>
                        </ol>
                    </div>

                    <!-- Support -->
                    <div class="cp-support-card">
                        <div class="cp-support-badge">HỖ TRỢ 24/7</div>
                        <div class="cp-support-title">Cần trợ giúp đăng bài?</div>
                        <p class="cp-support-desc">Nếu gặp khó khăn trong quá trình đăng tin, đừng ngần ngại liên hệ với đội ngũ hỗ trợ Unistay.</p>
                        <a href="#" class="cp-support-link">
                            Trung tâm hỗ trợ <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                </aside>
            </div>
        </div>
    </div>

    <!-- ===== FOOTER ===== -->
    <footer class="cp-footer">
        <div class="cp-footer-inner">
            <div class="cp-footer-brand-col">
                <div class="cp-footer-brand">UniStay</div>
                <p>Hệ thống tìm phòng trọ và ở ghép hàng đầu dành cho sinh viên Việt Nam.</p>
                <div class="cp-footer-socials">
                    <a href="#"><i class="fas fa-globe"></i></a>
                    <a href="#"><i class="fas fa-at"></i></a>
                </div>
            </div>
            <div>
                <div class="cp-footer-heading">Khám phá</div>
                <a href="#">Tìm phòng gần trường</a>
                <a href="#">Tìm bạn ở ghép mới</a>
                <a href="#">Tin tức sinh viên</a>
                <a href="#">Cẩm nang thuê trọ</a>
            </div>
            <div>
                <div class="cp-footer-heading">Công ty</div>
                <a href="#">Về chúng tôi</a>
                <a href="#">Tuyển dụng</a>
                <a href="#">Đối tác</a>
                <a href="#">Báo chí</a>
            </div>
            <div>
                <div class="cp-footer-heading">Tải ứng dụng</div>
                <a href="#" class="cp-store-btn">
                    <i class="fab fa-google-play"></i>
                    <div><span>GET IT ON</span><strong>Google Play</strong></div>
                </a>
                <a href="#" class="cp-store-btn">
                    <i class="fab fa-apple"></i>
                    <div><span>DOWNLOAD ON THE</span><strong>App Store</strong></div>
                </a>
            </div>
        </div>
        <div class="cp-footer-bottom">
            <span>© 2024 Unistay Corp. All rights reserved.</span>
            <div class="cp-footer-links">
                <a href="#">Điều khoản dịch vụ</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Cài đặt Cookie</a>
            </div>
        </div>
    </footer>

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Post type toggle
            document.querySelectorAll('.cp-type-card').forEach(card => {
                card.addEventListener('click', function () {
                    document.querySelectorAll('.cp-type-card').forEach(c => c.classList.remove('cp-type-active'));
                    this.classList.add('cp-type-active');
                });
            });

            // Gender radio sync to hidden input
            document.querySelectorAll('input[name="genderSelect"]').forEach(radio => {
                radio.addEventListener('change', function () {
                    document.getElementById('genderHidden').value = this.value;
                    document.querySelectorAll('.cp-gender-opt').forEach(o => o.classList.remove('active'));
                    this.closest('.cp-gender-opt').classList.add('active');
                });
            });

            // Move-in date sync
            const moveInPicker = document.querySelector('input[name="moveInDatePicker"]');
            if (moveInPicker) {
                moveInPicker.addEventListener('change', function () {
                    document.getElementById('moveInHidden').value = this.value;
                });
            }

            // Habits chips
            document.querySelectorAll('.cp-habit-chip input').forEach(cb => {
                cb.addEventListener('change', function () {
                    this.closest('.cp-habit-chip').classList.toggle('active', this.checked);
                    updateHabits();
                });
            });

            function updateHabits() {
                const selected = Array.from(document.querySelectorAll('.cp-habit-chip input:checked'))
                    .map(cb => cb.value);
                document.getElementById('HabitsInput').value = selected.join(', ');
            }
            updateHabits();

            // Image upload preview
            const fileInput = document.getElementById('avatarUpload');
            const previewRow = document.getElementById('previewRow');
            const uploadZone = document.getElementById('uploadZone');

            uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('cp-upload-drag'); });
            uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('cp-upload-drag'));
            uploadZone.addEventListener('drop', e => {
                e.preventDefault();
                uploadZone.classList.remove('cp-upload-drag');
                handleFiles(e.dataTransfer.files);
            });

            fileInput.addEventListener('change', function () {
                handleFiles(this.files);
            });

            function handleFiles(files) {
                Array.from(files).slice(0, 5).forEach(file => {
                    if (!file.type.startsWith('image/')) return;
                    const reader = new FileReader();
                    reader.onload = e => {
                        const thumb = document.createElement('div');
                        thumb.className = 'cp-thumb';
                        thumb.innerHTML = `<img src="${e.target.result}" alt="preview"><button type="button" class="cp-thumb-remove"><i class="fas fa-times"></i></button>`;
                        thumb.querySelector('.cp-thumb-remove').addEventListener('click', () => thumb.remove());
                        previewRow.appendChild(thumb);
                    };
                    reader.readAsDataURL(file);
                });
            }
        });

        function saveDraft() {
            const btn = document.querySelector('.cp-btn-draft');
            btn.innerHTML = '<i class="fas fa-check"></i> Đã lưu nháp';
            btn.style.color = '#10b981';
            setTimeout(() => { btn.innerHTML = '<i class="fas fa-save"></i> Lưu nháp'; btn.style.color = ''; }, 2000);
        }
    </script>
}
