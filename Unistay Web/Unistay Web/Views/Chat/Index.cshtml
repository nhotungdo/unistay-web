@{
    ViewData["Title"] = "Tin nhắn - Unistay";
    var currentUser = ViewBag.CurrentUserId as string;
    var selectedFriendId = ViewBag.SelectedFriendId as string;
}

@section Styles {
<style>
    body { background: #F0F4F8 !important; overflow: hidden; }

    .msg-layout {
        display: grid;
        grid-template-columns: 200px 300px 1fr 280px;
        height: calc(100vh - 80px);
        background: #F0F4F8;
        gap: 0;
    }

    /* ===== LEFT NAV SIDEBAR ===== */
    .msg-nav {
        background: #1B3F35;
        display: flex;
        flex-direction: column;
        padding: 0;
        overflow: hidden;
    }

    .msg-nav-brand {
        padding: 20px 16px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .msg-nav-brand-row {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .msg-nav-brand-icon {
        width: 38px; height: 38px;
        background: #2DBE8C;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 17px; color: white; flex-shrink: 0;
    }

    .msg-nav-brand-name { font-size: 14px; font-weight: 800; color: #fff; line-height: 1.2; }
    .msg-nav-brand-sub { font-size: 10px; color: rgba(255,255,255,0.45); }

    .msg-nav-items {
        display: flex; flex-direction: column; gap: 2px;
        padding: 16px 12px;
        flex: 1;
    }

    .msg-nav-item {
        display: flex; align-items: center; gap: 10px;
        padding: 10px 12px; border-radius: 10px;
        font-size: 13px; font-weight: 600;
        color: rgba(255,255,255,0.55);
        text-decoration: none; cursor: pointer;
        transition: all 0.15s;
    }

    .msg-nav-item:hover { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.9); }
    .msg-nav-item.active { background: rgba(255,255,255,0.13); color: #fff; }
    .msg-nav-item i { width: 16px; text-align: center; font-size: 14px; }

    /* ===== CONVERSATION LIST ===== */
    .msg-convlist {
        background: #fff;
        border-right: 1px solid #E8EDF2;
        display: flex; flex-direction: column;
        overflow: hidden;
    }

    .msg-conv-search {
        padding: 14px 16px 10px;
        flex-shrink: 0;
    }

    .msg-conv-searchbox {
        display: flex; align-items: center; gap: 8px;
        background: #F1F5F9; border-radius: 10px;
        padding: 8px 12px;
    }

    .msg-conv-searchbox i { color: #94A3B8; font-size: 13px; }

    .msg-conv-searchbox input {
        background: none; border: none; outline: none;
        font-size: 13px; color: #1E293B; width: 100%;
    }

    .msg-conv-searchbox input::placeholder { color: #94A3B8; }

    .msg-conv-header {
        display: flex; justify-content: space-between; align-items: center;
        padding: 4px 16px 10px;
        flex-shrink: 0;
    }

    .msg-conv-label {
        font-size: 11px; font-weight: 800; color: #94A3B8;
        text-transform: uppercase; letter-spacing: 0.07em;
    }

    .msg-new-badge {
        background: #2563EB; color: #fff;
        font-size: 10px; font-weight: 800;
        padding: 2px 8px; border-radius: 99px;
    }

    .msg-conv-items { flex: 1; overflow-y: auto; }
    .msg-conv-items::-webkit-scrollbar { width: 3px; }
    .msg-conv-items::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 4px; }

    .contact-card {
        display: flex; align-items: center; gap: 12px;
        padding: 12px 16px; cursor: pointer;
        transition: background 0.15s; border-bottom: 1px solid #F8FAFC;
        position: relative;
    }

    .contact-card:hover { background: #F8FAFC; }
    .contact-card.active { background: #EFF6FF; }

    .contact-avatar-wrap { position: relative; flex-shrink: 0; }

    .contact-avatar {
        width: 44px; height: 44px;
        border-radius: 50%; object-fit: cover;
    }

    .contact-avatar-placeholder {
        width: 44px; height: 44px; border-radius: 50%;
        background: linear-gradient(135deg, #2563EB, #0EA5E9);
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 15px; font-weight: 800;
    }

    .online-status {
        position: absolute; bottom: 1px; right: 1px;
        width: 11px; height: 11px;
        background: #10B981; border: 2px solid #fff;
        border-radius: 50%;
    }

    .contact-info { flex: 1; min-width: 0; }

    .contact-top-row {
        display: flex; justify-content: space-between;
        align-items: baseline; margin-bottom: 3px;
    }

    .contact-name {
        font-size: 13px; font-weight: 700; color: #0F172A;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        max-width: 140px;
    }

    .message-time { font-size: 11px; color: #94A3B8; flex-shrink: 0; }

    .contact-bottom-row { display: flex; flex-direction: column; gap: 2px; }

    .message-preview {
        font-size: 12px; color: #64748B;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }

    .contact-location {
        font-size: 11px; color: #94A3B8;
        display: flex; align-items: center; gap: 3px;
    }

    /* ===== MAIN CHAT ===== */
    .msg-chat-main {
        background: #FAFBFC;
        display: flex; flex-direction: column;
        overflow: hidden;
        border-right: 1px solid #E8EDF2;
    }

    .msg-chat-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 14px 24px;
        background: #fff; border-bottom: 1px solid #E8EDF2;
        flex-shrink: 0;
    }

    #chatHeader { visibility: hidden; }

    .msg-header-user { display: flex; align-items: center; gap: 12px; }

    #activeAvatar {
        width: 40px; height: 40px;
        border-radius: 50%; object-fit: cover;
    }

    #activeName { font-size: 15px; font-weight: 800; color: #0F172A; }
    #headerStatus { font-size: 12px; color: #10B981; font-weight: 600; }

    .msg-header-actions { display: flex; gap: 6px; }

    .msg-icon-btn {
        width: 36px; height: 36px; background: #F1F5F9;
        border: none; border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        color: #64748B; cursor: pointer; font-size: 15px;
        transition: all 0.15s;
    }
    .msg-icon-btn:hover { background: #EFF6FF; color: #2563EB; }

    .msg-date-divider {
        text-align: center; margin: 16px 0; font-size: 11px;
        font-weight: 700; color: #94A3B8;
        text-transform: uppercase; letter-spacing: 0.08em;
    }

    .chat-messages-area {
        flex: 1; overflow-y: auto; padding: 16px 24px;
        display: flex; flex-direction: column; gap: 4px;
    }

    .chat-messages-area::-webkit-scrollbar { width: 4px; }
    .chat-messages-area::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 4px; }

    .message-row { display: flex; align-items: flex-end; gap: 8px; margin-bottom: 4px; }
    .message-row.sent { flex-direction: row-reverse; }

    .msg-row-avatar {
        width: 32px; height: 32px; border-radius: 50%;
        object-fit: cover; flex-shrink: 0;
    }

    .message-bubble {
        max-width: 70%; padding: 12px 15px;
        border-radius: 16px; font-size: 13.5px; line-height: 1.6;
    }

    .received .message-bubble {
        background: #F1F5F9; color: #1E293B;
        border-bottom-left-radius: 4px;
    }

    .sent .message-bubble {
        background: linear-gradient(135deg, #2563EB, #1D4ED8);
        color: #fff; border-bottom-right-radius: 4px;
        box-shadow: 0 4px 14px rgba(37,99,235,0.25);
    }

    .msg-meta { font-size: 11px; color: #94A3B8; margin-top: 5px; }
    .sent .msg-meta { color: rgba(255,255,255,0.65); }

    /* Room card in message */
    .msg-room-card {
        background: #fff; border-radius: 12px; overflow: hidden;
        border: 1px solid #E2E8F0; margin-top: 8px; max-width: 240px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .msg-room-card img { width: 100%; height: 120px; object-fit: cover; }

    .msg-room-card-body { padding: 10px 12px; }

    .msg-room-card-name {
        font-size: 12px; font-weight: 700; color: #2563EB; margin-bottom: 3px;
    }

    .msg-room-card-price { font-size: 12px; color: #64748B; }

    .empty-state {
        flex: 1; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        color: #94A3B8; gap: 12px;
    }

    .empty-state i { font-size: 48px; }
    .empty-state p { font-size: 14px; font-weight: 500; }

    /* Compose bar */
    .compose-bar {
        display: none; align-items: center; gap: 10px;
        padding: 14px 24px 18px;
        background: #fff; border-top: 1px solid #E8EDF2;
        flex-shrink: 0;
    }

    #messageInput {
        flex: 1; border: none; outline: none; resize: none;
        font-size: 13.5px; color: #1E293B;
        background: transparent; font-family: inherit;
        max-height: 100px; overflow-y: auto;
    }

    #messageInput::placeholder { color: #94A3B8; }

    .compose-input-wrap {
        flex: 1; background: #F8FAFC;
        border: 1.5px solid #E2E8F0; border-radius: 14px;
        padding: 10px 14px; display: flex; align-items: center; gap: 8px;
        transition: border-color 0.2s;
    }

    .compose-input-wrap:focus-within { border-color: #2563EB; }

    .btn-send {
        width: 40px; height: 40px;
        background: #2563EB; border: none; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: white; font-size: 15px; cursor: pointer;
        box-shadow: 0 4px 12px rgba(37,99,235,0.3); flex-shrink: 0;
        transition: all 0.2s;
    }
    .btn-send:hover { transform: scale(1.08); background: #1D4ED8; }

    .compose-icon-btn {
        background: none; border: none; color: #94A3B8;
        font-size: 17px; cursor: pointer; padding: 2px;
        transition: color 0.15s; flex-shrink: 0;
    }
    .compose-icon-btn:hover { color: #2563EB; }

    /* ===== RIGHT INFO PANEL ===== */
    .msg-info-panel {
        background: #F8FAFC;
        overflow-y: auto; padding: 20px 16px;
        display: flex; flex-direction: column; gap: 16px;
    }

    .msg-info-panel::-webkit-scrollbar { width: 3px; }
    .msg-info-panel::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 4px; }

    .msg-profile-hero {
        text-align: center; padding: 8px 0 4px;
    }

    .msg-profile-avatar {
        width: 72px; height: 72px; border-radius: 50%;
        object-fit: cover; margin: 0 auto 10px;
        border: 3px solid #EFF6FF; display: block;
        background: #E2E8F0;
    }

    .msg-profile-name {
        font-size: 15px; font-weight: 800; color: #0F172A; margin-bottom: 3px;
    }

    .msg-profile-role { font-size: 12px; color: #64748B; }

    .msg-profile-stats {
        display: flex; gap: 16px; justify-content: center;
        margin-top: 12px; padding-top: 12px;
        border-top: 1px solid #E2E8F0;
    }

    .msg-stat { text-align: center; }
    .msg-stat-val { font-size: 16px; font-weight: 800; color: #0F172A; }
    .msg-stat-label { font-size: 9px; font-weight: 700; color: #94A3B8; text-transform: uppercase; letter-spacing: 0.06em; margin-top: 2px; }

    .msg-info-section-label {
        font-size: 10px; font-weight: 800; color: #94A3B8;
        text-transform: uppercase; letter-spacing: 0.08em;
        margin-bottom: 10px;
    }

    .msg-room-info-card {
        background: #fff; border-radius: 14px;
        border: 1px solid #E2E8F0;
        overflow: hidden;
    }

    .msg-room-info-img { width: 100%; height: 100px; object-fit: cover; }

    .msg-room-info-body { padding: 12px; }

    .msg-room-info-name {
        font-size: 13px; font-weight: 800; color: #0F172A; margin-bottom: 4px;
    }

    .msg-room-info-loc {
        font-size: 11px; color: #64748B;
        display: flex; align-items: center; gap: 4px; margin-bottom: 8px;
    }

    .msg-room-info-footer {
        display: flex; justify-content: space-between; align-items: center;
    }

    .msg-room-price { font-size: 14px; font-weight: 800; color: #2563EB; }

    .msg-room-status {
        background: #DCFCE7; color: #166534;
        font-size: 10px; font-weight: 800;
        padding: 3px 10px; border-radius: 99px;
    }

    .msg-amenities-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    }

    .msg-amenity {
        display: flex; align-items: center; gap: 6px;
        background: #fff; border: 1px solid #E2E8F0;
        border-radius: 8px; padding: 8px 10px;
        font-size: 11px; font-weight: 600; color: #475569;
    }

    .msg-amenity i { color: #2563EB; font-size: 12px; }

    .msg-attachment {
        display: flex; align-items: center; gap: 10px;
        background: #fff; border: 1px solid #E2E8F0;
        border-radius: 10px; padding: 10px 12px;
    }

    .msg-attach-icon {
        width: 34px; height: 34px; border-radius: 8px;
        background: #FEE2E2; display: flex; align-items: center;
        justify-content: center; color: #EF4444; font-size: 14px; flex-shrink: 0;
    }

    .msg-attach-name { font-size: 12px; font-weight: 700; color: #0F172A; }
    .msg-attach-size { font-size: 11px; color: #94A3B8; }

    /* ===== FOOTER ===== */
    .msg-footer {
        background: #fff; border-top: 1px solid #E2E8F0;
        padding: 14px 24px;
        display: flex; justify-content: space-between; align-items: center;
        font-size: 12px; color: #94A3B8;
        flex-shrink: 0;
    }

    .msg-footer-links { display: flex; gap: 20px; }
    .msg-footer-links a { color: #94A3B8; text-decoration: none; font-size: 12px; }
    .msg-footer-links a:hover { color: #2563EB; }

    .loading-spinner { display: flex; justify-content: center; padding: 40px; }

    .emoji-picker {
        position: absolute; bottom: 52px; right: 60px;
        background: white; border: 1px solid #E2E8F0;
        border-radius: 12px; padding: 10px; width: 260px; height: 200px;
        overflow-y: auto; display: grid;
        grid-template-columns: repeat(6, 1fr);
        gap: 4px; box-shadow: 0 8px 24px rgba(0,0,0,0.12);
        z-index: 1000;
    }

    .emoji-btn { background: none; border: none; font-size: 20px; cursor: pointer; padding: 4px; border-radius: 6px; }
    .emoji-btn:hover { background: #F1F5F9; }

    @@media (max-width: 1200px) {
        .msg-layout { grid-template-columns: 200px 280px 1fr; }
        .msg-info-panel { display: none; }
    }

    @@media (max-width: 900px) {
        .msg-layout { grid-template-columns: 1fr; }
        .msg-nav { display: none; }
        .msg-convlist { display: none; }
    }
</style>
}

<div style="display:flex; flex-direction:column; height:calc(100vh - 80px);">
<div class="msg-layout">

    <!-- LEFT NAV -->
    <aside class="msg-nav">
        <div class="msg-nav-brand">
            <div class="msg-nav-brand-row">
                <div class="msg-nav-brand-icon"><i class="fas fa-home"></i></div>
                <div>
                    <div class="msg-nav-brand-name">Quản lý</div>
                    <div class="msg-nav-brand-sub">FPT University Hanoi</div>
                </div>
            </div>
        </div>
        <div class="msg-nav-items">
            <a class="msg-nav-item" asp-controller="Home" asp-action="Index">
                <i class="fas fa-th-large"></i> Bảng điều khiển
            </a>
            <a class="msg-nav-item active" asp-controller="Messages" asp-action="Index">
                <i class="fas fa-comment-dots"></i> Tin nhắn
            </a>
            <a class="msg-nav-item" asp-controller="Rooms" asp-action="Index">
                <i class="fas fa-bed"></i> Phòng của tôi
            </a>
            <a class="msg-nav-item" asp-controller="Account" asp-action="Profile">
                <i class="fas fa-cog"></i> Cài đặt
            </a>
        </div>
    </aside>

    <!-- CONVERSATION LIST -->
    <div class="msg-convlist">
        <div class="msg-conv-search">
            <div class="msg-conv-searchbox">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Tìm cuộc hội thoại..." id="searchContacts" />
            </div>
        </div>
        <div class="msg-conv-header">
            <span class="msg-conv-label">Hộp thư</span>
            <span class="msg-new-badge">4 mới</span>
        </div>
        <div class="msg-conv-items" id="contactsList">
            @if (ViewBag.Friends != null)
            {
                foreach (var friend in ViewBag.Friends)
                {
                    <div class="contact-card" onclick="selectUser('@friend.Id','@friend.FullName','@friend.AvatarUrl')"
                         data-user-id="@friend.Id" data-name="@friend.FullName">
                        <div class="contact-avatar-wrap">
                            <img src="@(friend.AvatarUrl ?? "https://ui-avatars.com/api/?name=" + friend.FullName + "&background=2563EB&color=fff")"
                                 class="contact-avatar" alt="@friend.FullName" />
                            <span class="online-status" id="status-@friend.Id" style="display:none;"></span>
                        </div>
                        <div class="contact-info">
                            <div class="contact-top-row">
                                <span class="contact-name">@friend.FullName</span>
                                <span class="message-time"></span>
                            </div>
                            <div class="contact-bottom-row">
                                <span class="message-preview">Bắt đầu trò chuyện</span>
                            </div>
                        </div>
                    </div>
                }
            }
            @if (ViewBag.Groups != null)
            {
                foreach (var group in ViewBag.Groups)
                {
                    <div class="contact-card" onclick="selectGroup(@group.Id,'@group.Name')"
                         data-group-id="@group.Id" data-name="@group.Name">
                        <div class="contact-avatar-wrap">
                            <div class="contact-avatar-placeholder">G</div>
                        </div>
                        <div class="contact-info">
                            <div class="contact-top-row">
                                <span class="contact-name">@group.Name</span>
                                <span class="message-time"></span>
                            </div>
                            <div class="contact-bottom-row">
                                <span class="message-preview">Nhóm</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- MAIN CHAT -->
    <div class="msg-chat-main">
        <div class="msg-chat-header" id="chatHeader">
            <div class="msg-header-user">
                <button class="msg-icon-btn" onclick="backToSidebar()" style="margin-right:4px;">
                    <i class="fas fa-arrow-left"></i>
                </button>
                <img src="/images/default-user.png" id="activeAvatar" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />
                <div>
                    <div id="activeName" style="font-size:15px;font-weight:800;color:#0F172A;"></div>
                    <div id="headerStatus" style="font-size:12px;color:#10B981;font-weight:600;">
                        <span id="typingIndicator"></span>
                    </div>
                </div>
            </div>
            <div class="msg-header-actions">
                <button class="msg-icon-btn"><i class="fas fa-phone"></i></button>
                <button class="msg-icon-btn"><i class="fas fa-video"></i></button>
                <button class="msg-icon-btn"><i class="fas fa-info-circle"></i></button>
            </div>
        </div>

        <div class="chat-messages-area" id="messagesList">
            <div class="empty-state">
                <i class="fas fa-comment-alt"></i>
                <p>Chọn cuộc trò chuyện để bắt đầu</p>
            </div>
        </div>

        <div class="compose-bar" id="inputArea" style="position:relative;">
            <button class="compose-icon-btn" onclick="document.getElementById('fileInput').click()">
                <i class="fas fa-plus-circle"></i>
            </button>
            <button class="compose-icon-btn">
                <i class="fas fa-image"></i>
            </button>
            <input type="file" id="fileInput" hidden multiple onchange="handleFileSelect(this)" />
            <div class="compose-input-wrap" style="position:relative;">
                <div id="emojiPicker" class="emoji-picker" style="display:none;"></div>
                <textarea id="messageInput" rows="1" placeholder="Nhắn tin..." oninput="autoResize(this)"></textarea>
                <button class="compose-icon-btn" onclick="toggleEmojiPicker()">
                    <i class="far fa-smile"></i>
                </button>
            </div>
            <button class="btn-send" onclick="sendMessage()">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <!-- RIGHT INFO PANEL -->
    <aside class="msg-info-panel" id="rightPanel">
        <div class="msg-profile-hero">
            <img src="/images/default-user.png" id="panelAvatar" class="msg-profile-avatar" alt="avatar" />
            <div class="msg-profile-name" id="panelName">—</div>
            <div class="msg-profile-role" id="panelRole">Chọn một cuộc trò chuyện</div>
            <div class="msg-profile-stats">
                <div class="msg-stat">
                    <div class="msg-stat-val">4.8</div>
                    <div class="msg-stat-label">Đánh giá</div>
                </div>
                <div class="msg-stat">
                    <div class="msg-stat-val">5+</div>
                    <div class="msg-stat-label">Năm KN</div>
                </div>
            </div>
        </div>

        <div>
            <div class="msg-info-section-label">Thông tin phòng</div>
            <div class="msg-room-info-card">
                <img src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?w=400&q=80" class="msg-room-info-img" alt="room" />
                <div class="msg-room-info-body">
                    <div class="msg-room-info-name">Hòa Lạc Xanh – Phòng 302</div>
                    <div class="msg-room-info-loc"><i class="fas fa-map-marker-alt" style="color:#2563EB;font-size:10px;"></i> Thôn Tân Xã, Thạch Thất</div>
                    <div class="msg-room-info-footer">
                        <div class="msg-room-price">3.5Tr/tháng</div>
                        <span class="msg-room-status">Trống</span>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="msg-info-section-label">Tiện ích</div>
            <div class="msg-amenities-grid">
                <div class="msg-amenity"><i class="fas fa-snowflake"></i> Điều hòa</div>
                <div class="msg-amenity"><i class="fas fa-wifi"></i> Wifi</div>
                <div class="msg-amenity"><i class="fas fa-fire"></i> Nóng lạnh</div>
                <div class="msg-amenity"><i class="fas fa-motorcycle"></i> Chỗ để xe</div>
            </div>
        </div>

        <div>
            <div class="msg-info-section-label">Tệp đính kèm</div>
            <div class="msg-attachment">
                <div class="msg-attach-icon"><i class="fas fa-file-pdf"></i></div>
                <div>
                    <div class="msg-attach-name">Hop_dong_mau.pdf</div>
                    <div class="msg-attach-size">1.2 MB</div>
                </div>
            </div>
        </div>
    </aside>
</div>

<!-- Footer -->
<footer class="msg-footer">
    <span>© 2024 Unistay - Nền tảng nhà ở sinh viên FPT Hanoi</span>
    <div class="msg-footer-links">
        <a href="#">Điều khoản sử dụng</a>
        <a href="#">Chính sách bảo mật</a>
        <a href="#">Liên hệ hỗ trợ</a>
        <a href="#">Về chúng tôi</a>
    </div>
</footer>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    const currentUserId = '@currentUser';
    const initialFriendId = '@selectedFriendId';
    let activeChat = { type: null, id: null };
    let pendingMessages = JSON.parse(localStorage.getItem('pending_messages') || '[]');

    const emojis = ['😀','😃','😄','😁','😆','😅','😂','🤣','😊','😇','🙂','😉','😌','😍','🥰','😘','😋','😛','😝','😜','🤪','🤨','🧐','🤓','😎','🤩','🥳','😏','😒','😞','😔','😟','😕','🙁','☹️','😣','😖','😫','😩','🥺','😢','😭','😤','😠','😡','🤬','🤯','😳','🥵','🥶','😱','😨','😰','😥','😓','🤗','🤔','🤭','🤫','🤥','😶','😐','😑','😬','🙄','😯','😦','😧','😮','😲','😴','🤤','😪','😵','🤐','🥴','🤢','🤮','🤧','😷','🤒','🤕','🤑','🤠'];

    let connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub").withAutomaticReconnect().build();

    connection.on("UserOnline", (userId) => {
        const el = document.getElementById(`status-${userId}`);
        if (el) el.style.display = 'block';
    });
    connection.on("UserOffline", (userId) => {
        const el = document.getElementById(`status-${userId}`);
        if (el) el.style.display = 'none';
    });
    connection.on("ReceiveMessage", (msg) => {
        if ((activeChat.type === 'user' && (msg.senderId === activeChat.id || (msg.senderId === currentUserId && msg.receiverId === activeChat.id))) ||
            (activeChat.type === 'group' && msg.groupId === activeChat.id)) {
            if (msg.senderId !== currentUserId) connection.invoke("MessageRead", msg.id);
            appendMessage(msg, msg.senderId === currentUserId);
            scrollToBottom();
        } else {
            updateSidebarPreview(msg.groupId ? msg.groupId : msg.senderId, msg.content, !!msg.groupId);
            playNotificationSound();
        }
    });
    connection.on("MessageSent", (msg) => { console.log("Sent", msg); });
    connection.on("ConversationSeen", (data) => {
        if (activeChat.type === 'user' && activeChat.id === data.userId)
            document.querySelectorAll('.msg-status').forEach(el => el.innerHTML = '<i class="fas fa-check-double" style="color:#60A5FA;"></i> Đã xem');
    });
    connection.on("UserTyping", (userId, groupId) => {
        if (activeChat.type === 'user' && activeChat.id === userId) showTyping(true);
        if (activeChat.type === 'group' && activeChat.id === groupId && userId !== currentUserId) showTyping(true);
    });
    connection.on("UserStoppedTyping", () => showTyping(false));

    connection.start().then(() => {
        processPendingMessages();
        if (initialFriendId) {
            const card = document.querySelector(`.contact-card[data-user-id="${initialFriendId}"]`);
            if (card) card.click();
        }
    }).catch(e => console.error(e));

    function initEmojiPicker() {
        const c = document.getElementById('emojiPicker');
        c.innerHTML = emojis.map(e => `<button class="emoji-btn" onclick="addEmoji('${e}')">${e}</button>`).join('');
    }
    function toggleEmojiPicker() {
        const p = document.getElementById('emojiPicker');
        if (!p.innerHTML) initEmojiPicker();
        p.style.display = p.style.display === 'none' ? 'grid' : 'none';
    }
    function addEmoji(e) {
        const inp = document.getElementById('messageInput');
        inp.value += e; toggleEmojiPicker(); inp.focus();
    }
    function autoResize(t) {
        t.style.height = 'auto'; t.style.height = t.scrollHeight + 'px';
        if (!t.value) t.style.height = 'auto';
    }
    function handleFileSelect(input) {
        if (input.files.length > 0) {
            const msg = input.files.length === 1 ? input.files[0].name : `${input.files.length} tệp`;
            document.getElementById('messageInput').placeholder = msg;
        }
    }
    function selectUser(id, name, avatar) {
        activeChat = { type: 'user', id };
        loadChatUI(name, avatar || `https://ui-avatars.com/api/?name=${name}&background=2563EB&color=fff`);
        connection.invoke("MarkConversationAsSeen", id).catch(e => console.error(e));
        updateRightPanel(name, avatar);
    }
    function selectGroup(id, name) {
        activeChat = { type: 'group', id };
        loadChatUI(name, null);
    }
    function updateRightPanel(name, avatar) {
        document.getElementById('panelName').textContent = name;
        document.getElementById('panelRole').textContent = 'Chủ trọ tại Hòa Lạc';
        if (avatar) document.getElementById('panelAvatar').src = avatar;
    }
    function loadChatUI(name, avatar) {
        document.getElementById('activeName').textContent = name;
        document.getElementById('headerStatus').innerHTML = '<i class="fas fa-circle" style="font-size:8px;margin-right:4px;"></i> Đang hoạt động';
        document.getElementById('activeAvatar').src = avatar || '/images/default-user.png';
        document.getElementById('chatHeader').style.visibility = 'visible';
        document.getElementById('inputArea').style.display = 'flex';
        document.querySelectorAll('.contact-card').forEach(c => c.classList.remove('active'));
        const ac = document.querySelector(`.contact-card[data-user-id="${activeChat.id}"]`) ||
                   document.querySelector(`.contact-card[data-group-id="${activeChat.id}"]`);
        if (ac) ac.classList.add('active');
        loadHistory();
    }
    function backToSidebar() { activeChat = { type: null, id: null }; }
    async function loadHistory() {
        const list = document.getElementById('messagesList');
        list.innerHTML = '<div class="loading-spinner"><div style="width:32px;height:32px;border:3px solid #E2E8F0;border-top-color:#2563EB;border-radius:50%;animation:spin 0.8s linear infinite;"></div></div>';
        const url = activeChat.type === 'user' ? `/api/messages/${activeChat.id}` : `/api/messages/group/${activeChat.id}`;
        try {
            const res = await fetch(url);
            if (res.ok) {
                const data = await res.json();
                const msgs = data.data;
                list.innerHTML = '<div class="msg-date-divider">HÔM NAY</div>';
                msgs.forEach(m => {
                    if (m.attachments && (!m.attachmentPaths || !m.attachmentPaths.length))
                        m.attachmentPaths = m.attachments.map(a => a.filePath);
                    appendMessage(m, m.senderId === currentUserId);
                });
                scrollToBottom();
            } else { list.innerHTML = '<div class="msg-date-divider">Không có tin nhắn</div>'; }
        } catch(e) { console.error(e); list.innerHTML = ''; }
    }
    function appendMessage(msg, isMine) {
        const list = document.getElementById('messagesList');
        const row = document.createElement('div');
        row.className = `message-row ${isMine ? 'sent' : 'received'}`;
        let content = `<p style="margin:0;">${escapeHtml(msg.content)}</p>`;
        if (msg.attachmentPaths && msg.attachmentPaths.length > 0) {
            msg.attachmentPaths.forEach(path => {
                const ext = path.split('.').pop().toLowerCase();
                const isImg = ['jpg','jpeg','png','gif','webp'].includes(ext);
                if (isImg) {
                    content = `<img src="${path}" style="max-width:200px;border-radius:10px;margin-bottom:6px;display:block;">` + content;
                } else {
                    content = `<a href="${path}" target="_blank" style="display:flex;align-items:center;gap:6px;color:inherit;text-decoration:none;background:rgba(0,0,0,0.06);padding:8px;border-radius:8px;margin-bottom:6px;font-size:12px;">
                        <i class="fas fa-file-alt"></i>${path.split('/').pop()}</a>` + content;
                }
            });
        }
        const timeStr = formatTime(msg.createdAt || msg.timestamp);
        const statusHtml = isMine ? `<span class="msg-status" style="margin-left:4px;"><i class="fas fa-check" style="font-size:10px;"></i></span>` : '';
        const avatarSrc = isMine ? '' : (document.getElementById('activeAvatar').src);
        const avatarHtml = !isMine ? `<img src="${avatarSrc}" class="msg-row-avatar" />` : '';
        row.innerHTML = `${avatarHtml}<div class="message-bubble">${content}<div class="msg-meta">${timeStr}${statusHtml}</div></div>`;
        list.appendChild(row);
    }
    async function sendMessage() {
        const input = document.getElementById('messageInput');
        const text = input.value.trim();
        const fileInput = document.getElementById('fileInput');
        if (!text && fileInput.files.length === 0) return;
        input.value = ''; input.style.height = 'auto';
        input.placeholder = 'Nhắn tin...';
        const files = Array.from(fileInput.files);
        fileInput.value = '';
        let attachmentPaths = [], type = 'Text';
        if (files.length > 0) {
            type = 'File';
            for (const file of files) {
                const fd = new FormData(); fd.append('file', file);
                try {
                    const r = await fetch('/api/upload/message-attachment', { method: 'POST', body: fd });
                    if (r.ok) { const d = await r.json(); attachmentPaths.push(d.url); }
                } catch(e) { console.error(e); }
            }
        }
        const receiverId = activeChat.type === 'user' ? activeChat.id : null;
        const groupId = activeChat.type === 'group' ? activeChat.id : null;
        try {
            await connection.invoke("SendMessage", receiverId, groupId, text, attachmentPaths, type, null, false);
            appendMessage({ content: text, attachmentPaths, type, createdAt: new Date(), senderId: currentUserId, status: 'Sent' }, true);
            scrollToBottom();
        } catch(err) {
            console.error("Send failed", err);
            pendingMessages.push({ receiverId, groupId, text, attachmentPaths, type, timestamp: Date.now() });
            savePendingMessages();
        }
    }
    function savePendingMessages() { localStorage.setItem('pending_messages', JSON.stringify(pendingMessages)); }
    async function processPendingMessages() {
        if (!pendingMessages.length) return;
        const msgs = [...pendingMessages]; pendingMessages = []; savePendingMessages();
        for (const m of msgs) {
            try { await connection.invoke("SendMessage", m.receiverId, m.groupId, m.text, m.attachmentPaths, m.type, null, false); }
            catch(e) { pendingMessages.push(m); }
        }
        savePendingMessages();
    }
    document.getElementById('messageInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); return; }
        if (activeChat.id) {
            if (activeChat.type === 'user') connection.invoke("Typing", activeChat.id, null);
            else connection.invoke("Typing", null, activeChat.id);
        }
    });
    function scrollToBottom() { const l = document.getElementById('messagesList'); l.scrollTop = l.scrollHeight; }
    function escapeHtml(t) { if (!t) return ''; return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
    function formatTime(d) { if (!d) return 'Vừa xong'; return new Date(d).toLocaleTimeString('vi-VN', { hour: '2-digit', minute: '2-digit' }); }
    function showTyping(on) { document.getElementById('typingIndicator').textContent = on ? 'Đang nhập...' : ''; }
    function playNotificationSound() {}
    function updateSidebarPreview(id, text, isGroup) {
        const card = isGroup ? document.querySelector(`.contact-card[data-group-id="${id}"]`) : document.querySelector(`.contact-card[data-user-id="${id}"]`);
        if (card) { const prev = card.querySelector('.message-preview'); if (prev) prev.textContent = text; }
    }
    function showCreateGroupModal() { document.getElementById('createGroupModal').style.display = 'flex'; }
    function createGroup() {}
</script>
<style>@@keyframes spin { to { transform: rotate(360deg); } }</style>
}