            </div>
        </div>

        <!-- Room Card 6 -->
        <div class="room-card">
            <div class="room-image-wrapper">
                <img src="https://images.unsplash.com/photo-1552968561-deb8e0ac415e?w=400&h=300&fit=crop" alt="Phòng 6">
                <span class="room-badge"><i class="fas fa-crown"></i>Premium</span>
                <button class="room-favorite" title="Yêu thích">
                    <i class="far fa-heart"></i>
                </button>
            </div>
            <div class="room-info">
                <h3 class="room-title">Penthouse hạng sang, view thành phố tuyệt đẹp</h3>
                <div class="room-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Hà Nội, Ba Đình</span>
                </div>
                <div class="room-meta">
                    <div class="meta-item">
                        <i class="fas fa-ruler-combined"></i>
