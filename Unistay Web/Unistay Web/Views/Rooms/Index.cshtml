@{
    ViewData["Title"] = "Tìm Phòng Trọ - UniStay";
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/rooms.css" asp-append-version="true" />
    <style>
        body { padding: 0 !important; }
    </style>
}


<main class="rs-main-content">
    <div class="rs-container">
        <!-- Header -->
        <header class="rs-page-header">
            <h1 class="rs-page-title">Tìm phòng trọ lý tưởng<br>trên toàn quốc</h1>
            <p class="rs-page-subtitle">Khám phá hơn 50.000+ phòng trọ, chung cư mini và căn hộ dịch vụ tại các thành phố lớn trên cả nước.</p>
        </header>

        <!-- Filter Bar -->
        <div class="rs-filter-bar">
            <div class="rs-filter-group">
                <div class="rs-filter-item">
                    <i class="fas fa-dollar-sign"></i>
                    <span>Khoảng giá</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="rs-filter-item">
                    <i class="fas fa-home"></i>
                    <span>Loại phòng</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="rs-filter-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Khoảng cách</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
                <div class="rs-filter-item">
                    <i class="fas fa-check-circle"></i>
                    <span>Tiện ích</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>
            <div class="rs-sort-group">
                <span class="rs-sort-label">SẮP XẾP:</span>
                <div class="rs-sort-select">
                    <span>Mới nhất</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>
        </div>

        <!-- Layout Wrapper -->
        <div class="rs-content-wrapper">
            <!-- Listings Left -->
            <div class="rs-listings-column">
                <!-- Featured Card (Large) -->
                <div class="rs-card-featured">
                    <div class="rs-card-img-box">
                        <img src="https://images.unsplash.com/photo-1598928506311-c55ded91a20c?w=600&q=80" alt="Featured Room">
                        <span class="rs-badge-yellow">NỔI BẬT</span>
                    </div>
                    <div class="rs-card-info">
                        <div class="rs-card-header">
                            <h2 class="rs-card-title">Phòng Studio Full Nội Thất - Quận 1</h2>
                            <button class="rs-btn-heart"><i class="far fa-heart"></i></button>
                        </div>
                        <div class="rs-card-location-row">
                            <span><i class="fas fa-map-marker-alt"></i> Quận 1, TP. Hồ Chí Minh</span>
                            <span class="rs-spacer-dot"></span>
                            <span><i class="fas fa-walking"></i> 500m</span>
                        </div>
                        <div class="rs-card-amenities">
                            <span><i class="fas fa-snowflake"></i> Điều hòa</span>
                            <span><i class="fas fa-wifi"></i> Wifi tốc độ cao</span>
                            <span><i class="fas fa-door-open"></i> Ban công</span>
                            <span><i class="fas fa-shield-alt"></i> An ninh 24/7</span>
                        </div>
                        <div class="rs-card-footer">
                            <div class="rs-card-price">3.500.000đ <small>/ tháng</small></div>
                            <a href="#" class="rs-link-detail">Chi tiết <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </div>
                </div>

                <!-- Small Cards Grid -->
                <div class="rs-listings-grid">
                    <!-- Card 2 -->
                    <div class="rs-card-small">
                        <div class="rs-small-img-box">
                            <img src="https://images.unsplash.com/photo-1522771739844-649f6d175d97?w=400&q=80" alt="Room">
                            <span class="rs-badge-white">Mới đăng</span>
                        </div>
                        <div class="rs-small-info">
                            <h3 class="rs-small-title">Chung cư mini Cầu Giấy - Tiện nghi</h3>
                            <div class="rs-small-location"><i class="fas fa-map-marker-alt"></i> Quận Cầu Giấy, Hà Nội</div>
                            <div class="rs-small-footer">
                                <span class="rs-small-price">2.200.000đ</span>
                                <button class="rs-btn-bookmark"><i class="far fa-bookmark"></i></button>
                            </div>
                        </div>
                    </div>
                    <!-- Card 3 -->
                    <div class="rs-card-small">
                        <div class="rs-small-img-box">
                            <img src="https://images.unsplash.com/photo-1484154218962-a197022b5858?w=400&q=80" alt="Room">
                        </div>
                        <div class="rs-small-info">
                            <h3 class="rs-small-title">Phòng ở ghép cao cấp - Đà Nẵng</h3>
                            <div class="rs-small-location"><i class="fas fa-map-marker-alt"></i> Quận Hải Châu, Đà Nẵng</div>
                            <div class="rs-small-footer">
                                <span class="rs-small-price">1.500.000đ</span>
                                <button class="rs-btn-bookmark"><i class="far fa-bookmark"></i></button>
                            </div>
                        </div>
                    </div>
                    <!-- Card 4 -->
                    <div class="rs-card-small">
                        <div class="rs-small-img-box">
                            <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=400&q=80" alt="Room">
                        </div>
                        <div class="rs-small-info">
                            <h3 class="rs-small-title">Nhà nguyên căn 3 tầng - Thanh Xuân</h3>
                            <div class="rs-small-location"><i class="fas fa-map-marker-alt"></i> Quận Thanh Xuân, Hà Nội</div>
                            <div class="rs-small-footer">
                                <span class="rs-small-price">8.000.000đ</span>
                                <button class="rs-btn-bookmark"><i class="far fa-bookmark"></i></button>
                            </div>
                        </div>
                    </div>
                    <!-- Card 5 -->
                    <div class="rs-card-small">
                        <div class="rs-small-img-box">
                            <img src="https://images.unsplash.com/photo-1505691938895-1758d7eaa511?w=400&q=80" alt="Room">
                        </div>
                        <div class="rs-small-info">
                            <h3 class="rs-small-title">Phòng khép kín hiện đại - Bình Thạnh</h3>
                            <div class="rs-small-location"><i class="fas fa-map-marker-alt"></i> Quận Bình Thạnh, TP. HCM</div>
                            <div class="rs-small-footer">
                                <span class="rs-small-price">2.800.000đ</span>
                                <button class="rs-btn-bookmark"><i class="far fa-bookmark"></i></button>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="rs-load-more">
                    <button class="rs-btn-load-more">Xem thêm kết quả</button>
                </div>
            </div>

            <!-- Map Right -->
            <div class="rs-map-column">
                <div class="rs-map-wrapper">
                    <div class="rs-map-placeholder">
                        <div class="rs-map-pin" style="top: 25%; left: 35%;">3.5tr</div>
                        <div class="rs-map-pin" style="top: 45%; left: 55%;">2.2tr</div>
                        <div class="rs-map-pin active" style="top: 65%; left: 65%;">Trung tâm</div>
                        
                        <div class="rs-map-controls">
                            <button><i class="fas fa-plus"></i></button>
                            <button><i class="fas fa-minus"></i></button>
                            <button><i class="fas fa-location-arrow"></i></button>
                        </div>

                        <button class="rs-btn-expand-map">
                            <i class="fas fa-map"></i> Xem bản đồ lớn
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<footer class="rs-footer">
    <div class="rs-container">
        <div class="rs-footer-grid">
            <div class="rs-footer-col-brand">
                <div class="rs-footer-logo">Unistay</div>
                <p>Nền tảng tìm kiếm và quản lý nhà ở hàng đầu cho sinh viên và người đi làm tại các thành phố lớn trên toàn quốc.</p>
            </div>
            <div class="rs-footer-col">
                <h4>Liên kết</h4>
                <ul>
                    <li><a href="#">Tìm phòng</a></li>
                    <li><a href="#">Ở ghép</a></li>
                    <li><a href="#">Về chúng tôi</a></li>
                    <li><a href="#">Liên hệ hỗ trợ</a></li>
                </ul>
            </div>
            <div class="rs-footer-col">
                <h4>Chính sách</h4>
                <ul>
                    <li><a href="#">Điều khoản sử dụng</a></li>
                    <li><a href="#">Chính sách bảo mật</a></li>
                    <li><a href="#">Quy định đăng tin</a></li>
                </ul>
            </div>
            <div class="rs-footer-col">
                <h4>Kết nối</h4>
                <div class="rs-social-icons">
                    <a href="#"><i class="fas fa-envelope"></i></a>
                    <a href="#"><i class="fab fa-facebook"></i></a>
                </div>
            </div>
        </div>
        <div class="rs-footer-bottom">
            <p>© 2026 Unistay - Nền tảng thuê phòng sinh viên hàng đầu.</p>
            <div class="rs-footer-lang">
                <span>Vietnamese (VN)</span>
                <span>VND</span>
            </div>
        </div>
    </div>
</footer>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Toggle Heart Icon
            document.querySelectorAll('.rs-btn-heart').forEach(btn => {
                btn.addEventListener('click', function() {
                    const icon = this.querySelector('i');
                    if (icon.classList.contains('far')) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        this.style.color = '#ef4444';
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        this.style.color = '#64748B';
                    }
                });
            });

            // Toggle Bookmark Icon
            document.querySelectorAll('.rs-btn-bookmark').forEach(btn => {
                btn.addEventListener('click', function() {
                    const icon = this.querySelector('i');
                    if (icon.classList.contains('far')) {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        this.style.color = '#2563EB';
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        this.style.color = '#64748B';
                    }
                });
            });

            // Map Pin Interaction
            document.querySelectorAll('.rs-map-pin').forEach(pin => {
                pin.addEventListener('click', function() {
                    document.querySelectorAll('.rs-map-pin').forEach(p => p.classList.remove('active'));
                    this.classList.add('active');
                });
            });
        });
    </script>
}
