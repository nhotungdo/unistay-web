@{
    ViewData["Title"] = "Tìm Phòng & Căn Hộ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
<link href="~/css/rooms.css" rel="stylesheet">

<div class="hero-banner">
    <div class="hero-content">
        <h1><i class="fas fa-home me-2"></i>Tìm Phòng Của Bạn</h1>
        <p>Khám phá hàng ngàn phòng trọ, căn hộ chất lượng cao trên toàn quốc</p>
    </div>
</div>

<div class="container" style="margin-top: 2rem;">
    <!-- Search Bar -->
    <div class="search-container">
        <form class="search-form" method="get" asp-action="Index">
            <div class="form-group">
                <label for="searchLocation">Vị trí</label>
                <input type="text" id="searchLocation" name="location" placeholder="Nhập thành phố hoặc khu vực..." />
            </div>
            <div class="form-group">
                <label for="searchType">Loại phòng</label>
                <select id="searchType" name="type">
                    <option value="">-- Tất cả --</option>
                    <option value="phong-tro">Phòng trọ</option>
                    <option value="can-ho">Căn hộ</option>
                    <option value="ky-tuc-xa">Ký túc xá</option>
                    <option value="o-ghep">Ở ghép</option>
                </select>
            </div>
            <div class="form-group">
                <label for="searchPrice">Giá (VNĐ/tháng)</label>
                <select id="searchPrice" name="price">
                    <option value="">-- Tất cả --</option>
                    <option value="0-2">Dưới 2 triệu</option>
                    <option value="2-5">2-5 triệu</option>
                    <option value="5-10">5-10 triệu</option>
                    <option value="10">Trên 10 triệu</option>
                </select>
            </div>
            <button type="submit" class="btn-search">
                <i class="fas fa-search me-2"></i>Tìm kiếm
            </button>
        </form>
    </div>

    <!-- Filter Tags -->
    <div class="filter-tags">
        <span class="tag active"><i class="fas fa-fire me-2"></i>Phổ biến</span>
        <span class="tag"><i class="fas fa-star me-2"></i>Được yêu thích</span>
        <span class="tag"><i class="fas fa-tag me-2"></i>Giảm giá</span>
        <span class="tag"><i class="fas fa-clock me-2"></i>Mới nhất</span>
    </div>

    <!-- Room Listings -->
    <div class="rooms-grid">
        <!-- Room Card 1 -->
        <div class="room-card">
            <div class="room-image-wrapper">
                <img src="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=400&h=300&fit=crop" alt="Phòng 1">
                <span class="room-badge">Mới đăng</span>
                <button class="room-favorite" title="Yêu thích">
                    <i class="fas fa-heart"></i>
                </button>
            </div>
            <div class="room-info">
                <h3 class="room-title">Studio cao cấp, full nội thất, gần Đại học FPT</h3>
                <div class="room-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Hà Nội, Quận Cầu Giấy</span>
                </div>
                <div class="room-meta">
                    <div class="meta-item">
                        <i class="fas fa-ruler-combined"></i>
                        <span>32 m²</span>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-door-open"></i>
                        <span>1 người</span>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-wifi"></i>
                        <span>Wi-Fi</span>
                    </div>
                </div>
                <div class="room-price">3.5 triệu/tháng</div>
                <div class="room-controls">
                    <a href="#" class="btn-view">
                        <i class="fas fa-eye"></i>Xem chi tiết
                    </a>
                    <button class="btn-contact" onclick="alert('Liên hệ chủ phòng')">
                        <i class="fas fa-phone me-1"></i>Liên hệ
                    </button>
                </div>
            </div>
        </div>

        <!-- Room Card 2 -->
        <div class="room-card">
            <div class="room-image-wrapper">
                <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=400&h=300&fit=crop" alt="Phòng 2">
                <span class="room-badge featured"><i class="fas fa-star me-1"></i>Nổi bật</span>
                <button class="room-favorite" title="Yêu thích">
                    <i class="far fa-heart"></i>
                </button>
            </div>
            <div class="room-info">
                <h3 class="room-title">Căn hộ 2 phòng ngủ, ban công, thoáng sáng</h3>
                <div class="room-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Hà Nội, Thanh Xuân</span>
                </div>
                <div class="room-meta">
                    <div class="meta-item">
                        <i class="fas fa-ruler-combined"></i>
                        <span>65 m²</span>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-door-open"></i>
                        <span>2-3 người</span>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-tv"></i>
                        <span>TV Cable</span>
                    </div>
                </div>
                <div class="room-price">6.2 triệu/tháng</div>
                <div class="room-controls">
                    <a href="#" class="btn-view">
                        <i class="fas fa-eye"></i>Xem chi tiết
                    </a>
                    <button class="btn-contact" onclick="alert('Liên hệ chủ phòng')">
                        <i class="fas fa-phone me-1"></i>Liên hệ
                    </button>
                </div>
            </div>
        </div>

        <!-- Room Card 3 -->
        <div class="room-card">
            <div class="room-image-wrapper">
                <img src="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=400&h=300&fit=crop" alt="Phòng 3">
                <span class="room-badge"><i class="fas fa-percentage"></i>Giảm 10%</span>
                <button class="room-favorite" title="Yêu thích">
                    <i class="far fa-heart"></i>
                </button>
            </div>
            <div class="room-info">
                <h3 class="room-title">Phòng trọ tiêu chuẩn, an toàn 24/7, giáo dục tốt</h3>
                <div class="room-location">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Hà Nội, Hoàng Mai</span>
                </div>
                <div class="room-meta">
                    <div class="meta-item">
                        <i class="fas fa-ruler-combined"></i>
                        <span>28 m²</span>
                    </div>
                    <div class="meta-item">
                        <i class="fas fa-door-open"></i>
                        <span>1-2 người</span>
