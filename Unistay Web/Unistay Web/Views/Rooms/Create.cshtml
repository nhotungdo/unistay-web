@model Unistay_Web.Models.Room.Room
@{
    ViewData["Title"] = "Đăng tin phòng cho thuê - UniStay";
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/create-post.css" asp-append-version="true" />
}

<div class="cp-page">

    <!-- NAVBAR -->
    <header class="cp-navbar">
        <a asp-controller="Home" asp-action="Index" class="cp-brand">UniStay</a>
        <nav class="cp-nav">
            <a asp-controller="Rooms" asp-action="Index" class="active">Tìm phòng</a>
            <a asp-controller="Roommates" asp-action="Index">Ở ghép</a>
            <a href="#">Dịch vụ</a>
        </nav>
        <div class="cp-nav-right">
            <button class="cp-icon-btn" title="Thông báo"><i class="fas fa-bell"></i></button>
            <button class="cp-icon-btn" title="Tin nhắn"><i class="fas fa-comment-dots"></i></button>
            <div class="cp-avatar-wrap">
                <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(User.Identity?.Name ?? "U")&background=6366f1&color=fff" alt="avatar" />
            </div>
            <a asp-controller="Rooms" asp-action="Create" class="cp-btn-post">Đăng tin</a>
        </div>
    </header>

    <!-- BODY -->
    <div class="cp-body">
        <div class="cp-container">
            <div class="cp-heading">
                <div class="cp-step-label">BƯỚC ĐẦU TÌM TỔ ẤM</div>
                <h1 class="cp-title">Đăng tin mới</h1>
                <p class="cp-subtitle">Chia sẻ nhu cầu của bạn để tìm được căn phòng ưng ý hoặc những người bạn đồng hành tuyệt vời nhất.</p>
            </div>

            <div class="cp-layout">
                <div class="cp-form-col">
                    <!-- Post type selector -->
                    <div class="cp-type-selector">
                        <label class="cp-type-card cp-type-active">
                            <input type="radio" name="postType" value="room" checked />
                            <div class="cp-type-icon"><i class="fas fa-home"></i></div>
                            <div class="cp-type-info">
                                <div class="cp-type-title">Đăng tin cho thuê phòng</div>
                                <div class="cp-type-desc">Bạn có phòng trống và muốn tìm người thuê phù hợp.</div>
                            </div>
                        </label>
                        <a asp-controller="Roommates" asp-action="Create" class="cp-type-card" style="text-decoration:none">
                            <div class="cp-type-icon cp-type-icon-green"><i class="fas fa-user-friends"></i></div>
                            <div class="cp-type-info">
                                <div class="cp-type-title">Đăng tin tìm bạn ở ghép</div>
                                <div class="cp-type-desc">Bạn đang tìm người chia sẻ chi phí thuê phòng.</div>
                            </div>
                        </a>
                    </div>

                    <!-- Form card -->
                    <div class="cp-form-card">
                        <div class="cp-form-section-title">
                            <span class="cp-form-section-bar"></span> Thông tin cơ bản
                        </div>

                        <form asp-action="Create" method="post" enctype="multipart/form-data" id="mainForm">
                            @Html.AntiForgeryToken()

                            <div class="cp-field">
                                <label class="cp-label">Tiêu đề bài viết</label>
                                <input type="text" asp-for="Title" class="cp-input" placeholder="VD: Phòng trọ khu vực Bách Khoa, đầy đủ tiện nghi, gần trường" />
                                <span asp-validation-for="Title" class="cp-error"></span>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Nội dung chi tiết</label>
                                <textarea asp-for="Description" class="cp-textarea" placeholder="Mô tả chi tiết về phòng: diện tích, tiện ích, nội thất, quy định nhà trọ..."></textarea>
                                <span asp-validation-for="Description" class="cp-error"></span>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Địa chỉ phòng</label>
                                <div class="cp-input-icon-wrap">
                                    <i class="fas fa-map-marker-alt cp-input-icon"></i>
                                    <input type="text" asp-for="Address" class="cp-input cp-input-padded" placeholder="Số nhà, đường, phường/xã, quận/huyện, thành phố" />
                                </div>
                                <span asp-validation-for="Address" class="cp-error"></span>
                            </div>

                            <div class="cp-row-3">
                                <div class="cp-field">
                                    <label class="cp-label">Giá thuê (VNĐ/tháng)</label>
                                    <div class="cp-input-icon-wrap">
                                        <i class="fas fa-money-bill-wave cp-input-icon"></i>
                                        <input type="number" asp-for="Price" class="cp-input cp-input-padded" placeholder="VD: 3000000" />
                                    </div>
                                    <span asp-validation-for="Price" class="cp-error"></span>
                                </div>
                                <div class="cp-field">
                                    <label class="cp-label">Tiền cọc (VNĐ)</label>
                                    <div class="cp-input-icon-wrap">
                                        <i class="fas fa-shield-alt cp-input-icon"></i>
                                        <input type="number" asp-for="Deposit" class="cp-input cp-input-padded" placeholder="VD: 6000000" />
                                    </div>
                                </div>
                                <div class="cp-field">
                                    <label class="cp-label">Diện tích (m²)</label>
                                    <div class="cp-input-icon-wrap">
                                        <i class="fas fa-ruler-combined cp-input-icon"></i>
                                        <input type="number" asp-for="Area" class="cp-input cp-input-padded" placeholder="VD: 25" />
                                    </div>
                                </div>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Số người tối đa</label>
                                <div class="cp-occupant-row">
                                    @for (int i = 1; i <= 4; i++)
                                    {
                                        <label class="cp-occupant-opt @(i == 1 ? "active" : "")">
                                            <input type="radio" name="MaxOccupants" value="@i" @(i == 1 ? "checked" : "") />
                                            @i người
                                        </label>
                                    }
                                    <label class="cp-occupant-opt">
                                        <input type="radio" name="MaxOccupants" value="5" />
                                        5+ người
                                    </label>
                                </div>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Tiện ích có sẵn</label>
                                <div class="cp-habits-wrap">
                                    @{
                                        var amenityList = new (string icon, string name)[] {
                                                                        ("fas fa-wifi", "Wifi"),
                                                                        ("fas fa-snowflake", "Điều hòa"),
                                                                        ("fas fa-tshirt", "Máy giặt"),
                                                                        ("fas fa-parking", "Chỗ để xe"),
                                                                        ("fas fa-utensils", "Bếp nấu ăn"),
                                                                        ("fas fa-bath", "WC riêng"),
                                                                        ("fas fa-tv", "TV"),
                                                                        ("fas fa-couch", "Nội thất"),
                                                                        ("fas fa-shield-alt", "An ninh 24/7"),
                                                                        ("fas fa-bolt", "Điện nước riêng")
                                                                        };
                                        var currentAmenities = Model?.Amenities?.Split(',') ?? Array.Empty<string>();
                                    }
                                    @foreach (var item in amenityList)
                                    {
                                        var isChecked = currentAmenities.Contains(item.name);
                                        <label class="cp-habit-chip @(isChecked ? "active" : "")">
                                            <input type="checkbox" name="selectedAmenities" value="@item.name" @(isChecked ? "checked" : "") />
                                            <i class="@item.icon"></i> @item.name
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Quy định nhà trọ</label>
                                <div class="cp-habits-wrap">
                                    @{
                                        var ruleList = new[] { "Không hút thuốc", "Không thú cưng", "Không nấu ăn", "Không khách qua đêm", "Giờ giấc tự do", "Không ồn ào sau 22h" };
                                        var currentRules = Model?.Rules?.Split(',') ?? Array.Empty<string>();
                                    }
                                    @foreach (var rule in ruleList)
                                    {
                                        var isChecked = currentRules.Contains(rule);
                                        <label class="cp-habit-chip @(isChecked ? "active" : "")">
                                            <input type="checkbox" name="rulesList" value="@rule" @(isChecked ? "checked" : "") />
                                            @rule
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Hình ảnh phòng</label>
                                <label class="cp-upload-zone" for="imageUpload" id="uploadZone">
                                    <div class="cp-upload-inner">
                                        <div class="cp-upload-icon"><i class="fas fa-image"></i></div>
                                        <div class="cp-upload-text">Tải ảnh lên hoặc kéo thả vào đây</div>
                                        <div class="cp-upload-hint">Hỗ trợ JPG, PNG (Tối đa 5 ảnh, mỗi ảnh &lt; 5MB)</div>
                                    </div>
                                </label>
                                <input type="file" id="imageUpload" name="imageFiles" class="cp-file-input" accept="image/*" multiple />
                                <div class="cp-preview-row" id="previewRow"></div>
                            </div>

                            <div class="cp-field">
                                <label class="cp-label">Gói đăng tin</label>
                                <div class="cp-package-row">
                                    <label class="cp-package-opt active">
                                        <input type="radio" name="packageType" value="free" checked />
                                        <div class="cp-pkg-icon"><i class="fas fa-tag"></i></div>
                                        <div>
                                            <div class="cp-pkg-name">Miễn phí</div>
                                            <div class="cp-pkg-desc">Hiển thị thông thường, 30 ngày</div>
                                        </div>
                                    </label>
                                    <label class="cp-package-opt">
                                        <input type="radio" name="packageType" value="vip" />
                                        <div class="cp-pkg-icon cp-pkg-icon-gold"><i class="fas fa-crown"></i></div>
                                        <div>
                                            <div class="cp-pkg-name">VIP <span class="cp-pkg-badge">Nổi bật</span></div>
                                            <div class="cp-pkg-desc">Ưu tiên hiển thị, 60 ngày</div>
                                        </div>
                                    </label>
                                </div>
                                <input type="hidden" asp-for="IsVIP" id="isVipHidden" value="false" />
                            </div>

                            <input type="hidden" asp-for="Rules" id="rulesInput" />

                            <div class="cp-form-actions">
                                <button type="button" class="cp-btn-draft" onclick="saveDraft()">
                                    <i class="fas fa-save"></i> Lưu nháp
                                </button>
                                <button type="submit" class="cp-btn-submit">
                                    <i class="fas fa-check-circle"></i> Xác nhận Đăng tin
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <!-- SIDEBAR -->
                <aside class="cp-sidebar">
                    <div class="cp-tip-card">
                        <div class="cp-tip-header">
                            <div class="cp-tip-icon"><i class="fas fa-lightbulb"></i></div>
                            <span class="cp-tip-title">Mẹo đăng tin hiệu quả</span>
                        </div>
                        <ol class="cp-tip-list">
                            <li>Tiêu đề rõ ràng bao gồm khu vực và mục đích chính giúp tin của bạn dễ được tìm thấy hơn.</li>
                            <li>Cung cấp ít nhất 3 ảnh thật về không gian phòng để tăng độ tin cậy và thu hút người thuê.</li>
                            <li>Nêu rõ các quy tắc chung như giờ giấc, hút thuốc, hay thú cưng để lọc đối tác tương xứng.</li>
                        </ol>
                    </div>

                    <div class="cp-support-card">
                        <div class="cp-support-badge">HỖ TRỢ 24/7</div>
                        <div class="cp-support-title">Cần trợ giúp đăng bài?</div>
                        <p class="cp-support-desc">Nếu gặp khó khăn trong quá trình đăng tin, đừng ngần ngại liên hệ với đội ngũ hỗ trợ Unistay.</p>
                        <a href="#" class="cp-support-link">Trung tâm hỗ trợ <i class="fas fa-arrow-right"></i></a>
                    </div>

                    <div class="cp-preview-card">
                        <div class="cp-preview-card-title"><i class="fas fa-eye"></i> Xem trước tin đăng</div>
                        <div class="cp-mini-preview">
                            <div class="cp-mini-img"><i class="fas fa-home"></i></div>
                            <div class="cp-mini-info">
                                <div class="cp-mini-title" id="previewTitle">Tiêu đề bài viết...</div>
                                <div class="cp-mini-price" id="previewPrice">— đ/tháng</div>
                                <div class="cp-mini-addr" id="previewAddr"><i class="fas fa-map-marker-alt"></i> Địa chỉ...</div>
                            </div>
                        </div>
                    </div>
                </aside>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="cp-footer">
        <div class="cp-footer-inner">
            <div class="cp-footer-brand-col">
                <div class="cp-footer-brand">UniStay</div>
                <p>Hệ thống tìm phòng trọ và ở ghép hàng đầu dành cho sinh viên Việt Nam.</p>
                <div class="cp-footer-socials">
                    <a href="#"><i class="fas fa-globe"></i></a>
                    <a href="#"><i class="fas fa-at"></i></a>
                </div>
            </div>
            <div>
                <div class="cp-footer-heading">Khám phá</div>
                <a href="#">Tìm phòng gần trường</a>
                <a href="#">Tìm bạn ở ghép mới</a>
                <a href="#">Tin tức sinh viên</a>
                <a href="#">Cẩm nang thuê trọ</a>
            </div>
            <div>
                <div class="cp-footer-heading">Công ty</div>
                <a href="#">Về chúng tôi</a>
                <a href="#">Tuyển dụng</a>
                <a href="#">Đối tác</a>
                <a href="#">Báo chí</a>
            </div>
            <div>
                <div class="cp-footer-heading">Tải ứng dụng</div>
                <a href="#" class="cp-store-btn">
                    <i class="fab fa-google-play"></i>
                    <div><span>GET IT ON</span><strong>Google Play</strong></div>
                </a>
                <a href="#" class="cp-store-btn">
                    <i class="fab fa-apple"></i>
                    <div><span>DOWNLOAD ON THE</span><strong>App Store</strong></div>
                </a>
            </div>
        </div>
        <div class="cp-footer-bottom">
            <span>© 2026 Unistay Corp. All rights reserved.</span>
            <div class="cp-footer-links">
                <a href="#">Điều khoản dịch vụ</a>
                <a href="#">Chính sách bảo mật</a>
                <a href="#">Cài đặt Cookie</a>
            </div>
        </div>
    </footer>

</div>

@section Scripts {
    <script src="~/js/rooms-create.js" asp-append-version="true"></script>
}

            // Occupant radio
            document.querySelectorAll('input[name="MaxOccupants"]').forEach(r => {
                r.addEventListener('change', function () {
                    document.querySelectorAll('.cp-occupant-opt').forEach(o => o.classList.remove('active'));
                    this.closest('.cp-occupant-opt').classList.add('active');
                });
            });

            // Package toggle
            document.querySelectorAll('input[name="packageType"]').forEach(r => {
                r.addEventListener('change', function () {
                    document.querySelectorAll('.cp-package-opt').forEach(o => o.classList.remove('active'));
                    this.closest('.cp-package-opt').classList.add('active');
                    document.getElementById('isVipHidden').value = (this.value === 'vip').toString().toLowerCase();
                });
            });

            // Amenity chips
            document.querySelectorAll('input[name="selectedAmenities"]').forEach(cb => {
                cb.addEventListener('change', function () {
                    this.closest('.cp-habit-chip').classList.toggle('active', this.checked);
                });
            });

            // Rules chips + sync hidden
            function updateRules() {
                const selected = Array.from(document.querySelectorAll('input[name="rulesList"]:checked')).map(c => c.value);
                document.getElementById('rulesInput').value = selected.join(',');
            }
            document.querySelectorAll('input[name="rulesList"]').forEach(cb => {
                cb.addEventListener('change', function () {
                    this.closest('.cp-habit-chip').classList.toggle('active', this.checked);
                    updateRules();
                });
            });
            updateRules();

            // Live preview
            const titleInput = document.querySelector('input[name="Title"]');
            const priceInput = document.querySelector('input[name="Price"]');
            const addrInput = document.querySelector('input[name="Address"]');

            function updatePreview() {
                const t = titleInput?.value || 'Tiêu đề bài viết...';
                const p = priceInput?.value ? Number(priceInput.value).toLocaleString('vi-VN') + ' đ/tháng' : '— đ/tháng';
                const a = addrInput?.value || 'Địa chỉ...';
                document.getElementById('previewTitle').textContent = t.length > 40 ? t.slice(0, 40) + '...' : t;
                document.getElementById('previewPrice').textContent = p;
                document.getElementById('previewAddr').innerHTML = '<i class="fas fa-map-marker-alt"></i> ' + (a.length > 35 ? a.slice(0, 35) + '...' : a);
            }
            [titleInput, priceInput, addrInput].forEach(el => el?.addEventListener('input', updatePreview));

            // Image upload
            const fileInput = document.getElementById('imageUpload');
            const previewRow = document.getElementById('previewRow');
            const uploadZone = document.getElementById('uploadZone');

            uploadZone.addEventListener('dragover', e => { e.preventDefault(); uploadZone.classList.add('cp-upload-drag'); });
            uploadZone.addEventListener('dragleave', () => uploadZone.classList.remove('cp-upload-drag'));
            uploadZone.addEventListener('drop', e => {
                e.preventDefault();
                uploadZone.classList.remove('cp-upload-drag');
                handleFiles(e.dataTransfer.files);
            });
            fileInput.addEventListener('change', function () { handleFiles(this.files); });

            function handleFiles(files) {
                Array.from(files).slice(0, 5).forEach(file => {
                    if (!file.type.startsWith('image/')) return;
                    const reader = new FileReader();
                    reader.onload = e => {
                        const thumb = document.createElement('div');
                        thumb.className = 'cp-thumb';
                        thumb.innerHTML = `
<img src="${e.target.result}" alt="preview"><button type="button" class="cp-thumb-remove"><i class="fas fa-times"></i></button>`;
                        thumb.querySelector('.cp-thumb-remove').addEventListener('click', () => thumb.remove());
                        previewRow.appendChild(thumb);
                    };
                    reader.readAsDataURL(file);
                });
            }
        });

        function saveDraft() {
            const btn = document.querySelector('.cp-btn-draft');
            btn.innerHTML = '<i class="fas fa-check"></i> Đã lưu nháp';
            btn.style.color = '#10b981';
            setTimeout(() => { btn.innerHTML = '<i class="fas fa-save"></i> Lưu nháp'; btn.style.color = ''; }, 2000);
        }
</script>
}
