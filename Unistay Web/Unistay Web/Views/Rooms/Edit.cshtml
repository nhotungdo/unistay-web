@model Unistay_Web.Models.Room.Room
@{
    ViewData["Title"] = "Chỉnh sửa bài đăng phòng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<style>
    :root {
        --primary: #667eea;
        --primary-dark: #764ba2;
        --secondary: #f093fb;
        --success: #4ade80;
        --danger: #ef4444;
        --light: #f8fafc;
        --dark: #1e293b;
    }

    body {
        background: linear-gradient(135deg, var(--light) 0%, #f1f5f9 100%);
        min-height: 100vh;
        padding: 2rem 0;
    }

    /* Form Container */
    .form-container {
        max-width: 800px;
        margin: 0 auto;
    }

    .form-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .form-header h1 {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--dark);
        margin-bottom: 0.5rem;
    }

    .form-header p {
        font-size: 1.125rem;
        color: #64748b;
    }

    /* Form Card */
    .form-card {
        background: white;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    /* Section Header */
    .section-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-top: 2rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e2e8f0;
    }

    .section-header:first-of-type {
        margin-top: 0;
    }

    .section-number {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1.25rem;
    }

    .section-header h3 {
        margin: 0;
        font-weight: 700;
        color: var(--dark);
    }

    .section-header p {
        margin: 0;
        color: #64748b;
        font-size: 0.875rem;
    }

    /* Form Group */
    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        font-weight: 600;
        color: var(--dark);
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
    }

    .form-group label .required {
        color: var(--danger);
        margin-left: 0.25rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
        width: 100%;
        padding: 0.875rem 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        font-family: inherit;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
    }

    .form-group textarea {
        resize: vertical;
        min-height: 120px;
    }

    /* Help Text */
    .help-text {
        font-size: 0.875rem;
        color: #64748b;
        margin-top: 0.5rem;
    }

    /* Form Row */
    .form-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    /* Image Preview */
    .image-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 1rem;
        margin-top: 1.5rem;
    }

    .image-preview-item {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        aspect-ratio: 1;
    }

    .image-preview-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .remove-image {
        position: absolute;
        top: 5px;
        right: 5px;
        width: 32px;
        height: 32px;
        background: var(--danger);
        color: white;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        opacity: 0;
    }

    .image-preview-item:hover .remove-image {
        opacity: 1;
    }

    .remove-image:hover {
        transform: scale(1.1);
    }

    /* Amenities */
    .amenities-list {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 1rem;
    }

    .amenity-checkbox {
        display: none;
    }

    .amenity-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1rem;
        border: 2px solid #e2e8f0;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        background: white;
        font-weight: 500;
        color: #475569;
    }

    .amenity-checkbox:checked + .amenity-label {
        background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
        border-color: var(--primary);
        color: var(--primary);
    }

    .amenity-label:hover {
        border-color: var(--primary);
    }

    .amenity-label i {
        font-size: 1.25rem;
    }

    /* Buttons */
    .button-group {
        display: flex;
        gap: 1rem;
        margin-top: 2.5rem;
        justify-content: center;
    }

    .btn {
        padding: 0.875rem 2.5rem;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        font-size: 1rem;
        min-width: 150px;
    }

    .btn-primary {
        background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
        color: white;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary {
        background: white;
        color: var(--dark);
        border: 2px solid #e2e8f0;
    }

    .btn-secondary:hover {
        background: #f8fafc;
        border-color: var(--primary);
        color: var(--primary);
    }

    .btn-danger {
        background: var(--danger);
        color: white;
    }

    .btn-danger:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }

    /* Status Badge */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        background: rgba(74, 222, 128, 0.1);
        color: var(--success);
        border-radius: 10px;
        font-weight: 600;
        margin-top: 1rem;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .form-card {
            padding: 1.5rem;
        }

        .form-header h1 {
            font-size: 1.75rem;
        }

        .form-row {
            grid-template-columns: 1fr;
        }

        .amenities-list {
            grid-template-columns: repeat(2, 1fr);
        }

        .button-group {
            flex-direction: column;
        }
    }

    .validation-error {
        color: var(--danger);
        font-size: 0.875rem;
        margin-top: 0.5rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .validation-error i {
        font-size: 0.75rem;
    }
</style>

<div class="container form-container">
    <!-- Header -->
    <div class="form-header" style="margin-bottom: 2rem;">
        <h1><i class="fas fa-pen me-2"></i>Chỉnh sửa bài đăng</h1>
        <p>Cập nhật thông tin phòng của bạn</p>
    </div>

    <!-- Form Card -->
    <div class="form-card">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            <input type="hidden" name="id" value="@Model.Id" />

            <!-- SECTION 1: Basic Info -->
            <div class="section-header">
                <div class="section-number">1</div>
                <div>
                    <h3>Thông tin cơ bản</h3>
                    <p>Tiêu đề và mô tả phòng</p>
                </div>
            </div>

            <div class="form-group">
                <label for="Title">Tiêu đề bài đăng <span class="required">*</span></label>
                <input asp-for="Title" class="form-control" placeholder="VD: Studio cao cấp, full nội thất gần FPT" />
                <span asp-validation-for="Title" class="validation-error"><i class="fas fa-exclamation-circle"></i></span>
            </div>

            <div class="form-group">
                <label for="Description">Mô tả chi tiết <span class="required">*</span></label>
                <textarea asp-for="Description" class="form-control"></textarea>
                <span asp-validation-for="Description" class="validation-error"><i class="fas fa-exclamation-circle"></i></span>
            </div>

            <!-- SECTION 2: Specifics -->
            <div class="section-header">
                <div class="section-number">2</div>
                <div>
                    <h3>Thông số phòng</h3>
                    <p>Diện tích, loại phòng, số người tối đa</p>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Area">Diện tích (m²) <span class="required">*</span></label>
                    <input asp-for="Area" type="number" step="0.5" class="form-control" />
                    <span asp-validation-for="Area" class="validation-error"><i class="fas fa-exclamation-circle"></i></span>
                </div>

                <div class="form-group">
                    <label for="MaxOccupants">Số người tối đa</label>
                    <input asp-for="MaxOccupants" type="number" class="form-control" />
                </div>

                <div class="form-group">
                    <label for="Address">Địa chỉ chi tiết <span class="required">*</span></label>
                    <input asp-for="Address" class="form-control" />
                    <span asp-validation-for="Address" class="validation-error"><i class="fas fa-exclamation-circle"></i></span>
                </div>
            </div>

            <!-- SECTION 3: Pricing -->
            <div class="section-header">
                <div class="section-number">3</div>
                <div>
                    <h3>Chi phí</h3>
                    <p>Giá thuê, tiền cọc, chi phí khác</p>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="Price">Giá thuê (VNĐ/tháng) <span class="required">*</span></label>
                    <input asp-for="Price" type="number" class="form-control" />
                    <span asp-validation-for="Price" class="validation-error"><i class="fas fa-exclamation-circle"></i></span>
                </div>

                <div class="form-group">
                    <label for="Deposit">Tiền cọc (VNĐ)</label>
                    <input asp-for="Deposit" type="number" class="form-control" />
                    <p class="help-text">Để trống nếu không yêu cầu tiền cọc</p>
                </div>
            </div>

            <!-- SECTION 4: Status -->
            <div class="section-header">
                <div class="section-number">4</div>
                <div>
                    <h3>Trạng thái bài đăng</h3>
                    <p>Cập nhật tình trạng phòng</p>
                </div>
            </div>

            <div class="form-group">
                <label for="Status">Trạng thái</label>
                <select asp-for="Status" class="form-control">
                    <option value="Available">Còn trống</option>
                    <option value="Rented">Đã cho thuê</option>
                    <option value="Pending">Chờ xác nhận</option>
                </select>
            </div>

            <div class="status-badge" id="statusBadge">
                <i class="fas fa-info-circle"></i>
                <span id="statusText">Bài đăng của bạn đang hoạt động</span>
            </div>

            <!-- SECTION 5: Amenities -->
            <div class="section-header">
                <div class="section-number">5</div>
                <div>
                    <h3>Tiện ích & Dịch vụ</h3>
                    <p>Chọn các tiện ích có sẵn trong phòng</p>
                </div>
            </div>

            <input type="hidden" name="selectedAmenities" id="selectedAmenities" value="@Model.Amenities" />
            <div class="amenities-list">
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_wifi" name="amenities" value="wifi">
                    <label for="amenity_wifi" class="amenity-label">
                        <i class="fas fa-wifi"></i>
                        <span>Wi-Fi</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_ac" name="amenities" value="ac">
                    <label for="amenity_ac" class="amenity-label">
                        <i class="fas fa-snowflake"></i>
                        <span>Điều hòa</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_kitchen" name="amenities" value="kitchen">
                    <label for="amenity_kitchen" class="amenity-label">
                        <i class="fas fa-utensils"></i>
                        <span>Bếp</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_bathroom" name="amenities" value="bathroom">
                    <label for="amenity_bathroom" class="amenity-label">
                        <i class="fas fa-shower"></i>
                        <span>Phòng tắm</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_security" name="amenities" value="security">
                    <label for="amenity_security" class="amenity-label">
                        <i class="fas fa-shield"></i>
                        <span>24/7 An toàn</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_parking" name="amenities" value="parking">
                    <label for="amenity_parking" class="amenity-label">
                        <i class="fas fa-square-parking"></i>
                        <span>Chỗ để xe</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_tv" name="amenities" value="tv">
                    <label for="amenity_tv" class="amenity-label">
                        <i class="fas fa-tv"></i>
                        <span>TV Cable</span>
                    </label>
                </div>
                <div>
                    <input type="checkbox" class="amenity-checkbox" id="amenity_laundry" name="amenities" value="laundry">
                    <label for="amenity_laundry" class="amenity-label">
                        <i class="fas fa-person-drowning"></i>
                        <span>Giặt</span>
                    </label>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="button-group">
                <button type="button" class="btn btn-secondary" onclick="window.history.back()">
                    <i class="fas fa-arrow-left me-2"></i>Hủy
                </button>
                <button type="button" class="btn btn-danger" onclick="if(confirm('Bạn chắc chắn muốn xóa bài đăng này?')) { /* delete action */ }">
                    <i class="fas fa-trash me-2"></i>Xóa
                </button>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-check me-2"></i>Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Initialize amenities from existing data
    function initializeAmenities() {
        const amenitiesString = document.getElementById('selectedAmenities').value;
        if (amenitiesString) {
            const amenities = amenitiesString.split(',').map(a => a.trim());
            amenities.forEach(amenity => {
                const checkbox = document.querySelector(`#amenity_${amenity}`);
                if (checkbox) {
                    checkbox.checked = true;
                }
            });
        }
    }

    // Amenity selection
    document.querySelectorAll('.amenity-checkbox').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            const selected = Array.from(document.querySelectorAll('.amenity-checkbox:checked'))
                .map(c => c.value)
                .join(',');
            document.getElementById('selectedAmenities').value = selected;
        });
    });

    // Status update handling
    const statusSelect = document.querySelector('[name="Status"]');
    if (statusSelect) {
        statusSelect.addEventListener('change', function() {
            const statusBadge = document.getElementById('statusBadge');
            const statusText = document.getElementById('statusText');
            
            switch(this.value) {
                case 'Available':
                    statusBadge.style.background = 'rgba(74, 222, 128, 0.1)';
                    statusBadge.style.color = 'var(--success)';
                    statusText.textContent = '✓ Bài đăng đang hoạt động';
                    break;
                case 'Rented':
                    statusBadge.style.background = 'rgba(107, 114, 128, 0.1)';
                    statusBadge.style.color = '#757575';
                    statusText.textContent = '✓ Phòng đã cho thuê';
                    break;
                case 'Pending':
                    statusBadge.style.background = 'rgba(251, 191, 36, 0.1)';
                    statusBadge.style.color = '#fbbf24';
                    statusText.textContent = '⏳ Chờ xác nhận';
                    break;
            }
        });
    }

    // Initialize on page load
    window.addEventListener('load', initializeAmenities);
</script>
