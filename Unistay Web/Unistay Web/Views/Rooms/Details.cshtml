@model dynamic
@{
    ViewData["Title"] = "Căn hộ Studio Full nội thất - UniStay";
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/room-details.css" asp-append-version="true" />
    <style>
        body { padding: 0 !important; background-color: #fff; }
    </style>
}

<!-- ============================================================
     NAVBAR (Custom)
     ============================================================ -->
<nav class="rs-navbar">
    <div class="rs-container ns-nav-flex">
        <a class="rs-brand" asp-controller="Home" asp-action="Index">Unistay</a>

        <ul class="rs-nav-links">
            <li><a asp-controller="Rooms" asp-action="Index" class="active">Tìm phòng</a></li>
            <li><a asp-controller="Roommates" asp-action="Index">Ở ghép</a></li>
            <li><a href="#">Dịch vụ</a></li>
        </ul>

        <div class="rs-nav-actions">
            <a href="#" class="rs-btn-post">Đăng tin</a>
            <a asp-controller="Account" asp-action="Login" class="rs-btn-login-text">Đăng nhập</a>
            <div style="width: 32px; height: 32px; background: #E5E7EB; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #64748B;">
                <i class="fas fa-user"></i>
            </div>
        </div>
    </div>
</nav>

<div class="rd-container">
    <!-- Gallery -->
    <div class="rd-gallery-grid">
        <div class="rd-gallery-main">
            <span class="rd-badge-new">Phòng mới đăng</span>
            <img src="https://images.unsplash.com/photo-1596464716127-f2a82984de30?w=800&q=80" alt="Room Main">
        </div>
        <div class="rd-gallery-subs">
            <div class="rd-gallery-sub">
                <img src="https://images.unsplash.com/photo-1628592102751-ba83b0314276?w=400&q=80" alt="Sub 1">
            </div>
            <div class="rd-gallery-sub">
                <img src="https://images.unsplash.com/photo-1512918766674-ed62b9a79ad6?w=400&q=80" alt="Sub 2">
                <button class="rd-btn-all-photos">
                    <i class="fas fa-th"></i> Xem tất cả ảnh
                </button>
            </div>
        </div>
    </div>

    <div class="rd-content-wrapper">
        <!-- Left Column -->
        <main class="rd-main-info">
            <!-- Header Meta -->
            <div class="rd-meta-tags">
                <span class="rd-tag-type"><i class="fas fa-check-circle"></i> Phòng trọ cao cấp</span>
                <span class="rd-tag-loc">• Quận 7</span>
            </div>

            <!-- Title -->
            <h1 class="rd-title">Căn hộ Studio Full nội thất gần ĐH Tôn Đức Thắng</h1>

            <!-- Description -->
            <p class="rd-description">
                Phòng rộng 25m², thiết kế theo phong cách tối giản Bắc Âu, ngập tràn ánh sáng tự nhiên. Chỉ cách trường 5 phút đi xe, khu vực an ninh, yên tĩnh phù hợp cho sinh viên học tập.
            </p>

            <!-- Amenities -->
            <div>
                <h3 style="font-size: 16px; margin-bottom: 16px;">Tiện ích nổi bật</h3>
                <div class="rd-amenities-wrapper">
                    <div class="rd-amenities-strip">
                        <div class="rd-amenity-box">
                            <i class="fas fa-wifi"></i>
                            <span>Wifi tốc độ cao</span>
                        </div>
                        <div class="rd-amenity-box">
                            <i class="fas fa-snowflake"></i>
                            <span>Máy lạnh Inverter</span>
                        </div>
                        <div class="rd-amenity-box">
                            <i class="fas fa-tshirt"></i>
                            <span>Máy giặt riêng</span>
                        </div>
                        <div class="rd-amenity-box">
                            <i class="fas fa-key"></i>
                            <span>Khóa vân tay 24/7</span>
                        </div>
                    </div>
                    <button class="rd-btn-float-map">
                        <i class="fas fa-map-marked-alt"></i> Xem bản đồ khu vực
                    </button>
                </div>
            </div>

            <!-- Feng Shui Section -->
            <section class="rd-fengshui-section">
                <div class="rd-fs-header">
                    <div class="rd-fs-title">Góc Tâm Linh & Phong Thủy</div>
                    <span class="rd-fs-badge">AI PHÂN TÍCH</span>
                </div>
                
                <div class="rd-fs-grid">
                    <div class="rd-fs-card">
                        <div class="rd-fs-icon-wrap"><i class="fas fa-compass"></i></div>
                        <div class="rd-fs-label">HƯỚNG PHÒNG</div>
                        <div class="rd-fs-value">Đông Nam</div>
                        <div class="rd-fs-sub">Cung Tốn - Vượng khí</div>
                    </div>
                    <div class="rd-fs-card">
                        <div class="rd-fs-icon-wrap"><i class="fas fa-bolt"></i></div>
                        <div class="rd-fs-label">NĂNG LƯỢNG</div>
                        <div class="rd-fs-value">88% Cân bằng</div>
                        <div class="rd-fs-sub">Phù hợp học tập</div>
                    </div>
                    <div class="rd-fs-card">
                        <div class="rd-fs-icon-wrap"><i class="fas fa-tint"></i></div>
                        <div class="rd-fs-label">MỆNH PHÙ HỢP</div>
                        <div class="rd-fs-value">Mộc & Thủy</div>
                        <div class="rd-fs-sub">Tương sinh mạnh mẽ</div>
                    </div>
                </div>

                <div class="rd-fs-actions">
                    <button class="rd-btn-fs-ai">
                        <i class="fas fa-magic"></i> Xem chi tiết phong thủy với AI
                    </button>
                    <button class="rd-btn-fs-tarot">
                        <i class="fas fa-hand-sparkles"></i> Rút bài Tarot cho phòng này
                    </button>
                </div>
            </section>

            <!-- Location Section -->
            <section class="rd-map-section">
                <div class="rd-map-header">
                    <div style="font-weight: 800; font-size: 16px;">Vị trí & Bản đồ</div>
                    <a href="#" class="rd-map-link">Chi đường</a>
                </div>
                <div class="rd-map-address">Lê Văn Lương, Phường Tân Phong, Quận 7, TP. HCM</div>
                <div class="rd-map-frame" style="margin-top: 16px;">
                    <img src="https://images.unsplash.com/photo-1524661135-423995f22d0b?w=800&q=80" alt="Map Placeholder">
                    <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -100%); color: var(--rd-blue); font-size: 32px; filter: drop-shadow(0 4px 6px rgba(0,0,0,0.3));">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                </div>
            </section>
        </main>

        <!-- Right Column (Sidebar) -->
        <aside class="rd-sidebar">
            <div class="rd-booking-card">
                <div class="rd-price-row">
                    <div>
                        <div class="rd-price-label">Giá thuê hàng tháng</div>
                        <div class="rd-price-main">4.500.000đ</div>
                    </div>
                    <span class="rd-price-badge">Cọc 1 tháng</span>
                </div>

                <div class="rd-details-list">
                    <div class="rd-detail-item">
                        <span class="rd-detail-label">Điện</span>
                        <span class="rd-detail-value">3.500đ / KWh</span>
                    </div>
                    <div class="rd-detail-item">
                        <span class="rd-detail-label">Nước</span>
                        <span class="rd-detail-value">100.000đ / người</span>
                    </div>
                    <div class="rd-detail-item">
                        <span class="rd-detail-label">Dịch vụ (Rác, vệ sinh)</span>
                        <span class="rd-detail-value">150.000đ / phòng</span>
                    </div>
                </div>

                <button class="rd-btn-schedule">
                    <i class="far fa-calendar-alt"></i> Đặt lịch xem phòng
                </button>
                <button class="rd-btn-chat">
                    <i class="far fa-comment-dots"></i> Nhắn tin trao đổi
                </button>

                <!-- Host Info Card -->
                <div class="rd-host-card">
                    <img src="https://i.pravatar.cc/150?u=4" alt="Host" class="rd-host-avatar">
                    <div class="rd-host-info">
                        <div class="rd-host-name">Anh Minh Quân</div>
                        <div class="rd-host-rating"><i class="fas fa-star"></i> 4.9 <span style="color: #94A3B8; font-weight: 400;">(12 đánh giá)</span></div>
                    </div>
                </div>

                <div class="rd-host-actions">
                    <button class="rd-btn-call">
                        <i class="fas fa-phone-alt"></i> 0908 xxx xxx
                    </button>
                    <button class="rd-btn-share">
                        <i class="fas fa-share-alt"></i>
                    </button>
                </div>
            </div>
        </aside>
    </div>
</div>

<!-- ============================================================
     FOOTER (Sync with Index/Home)
     ============================================================ -->
<footer class="rs-footer" style="background: #E5E7EB;">
    <div class="rs-container">
        <div class="rs-footer-grid">
            <div class="rs-footer-col-brand">
                <div class="rs-footer-logo">Unistay</div>
                <p>Nền tảng tìm kiếm phòng trọ và ở ghép hàng đầu dành riêng cho sinh viên Việt Nam.</p>
            </div>
            <div class="rs-footer-col">
                <h4>Về chúng tôi</h4>
                <ul>
                    <li><a href="#">Câu chuyện thương hiệu</a></li>
                    <li><a href="#">Blog đời sống</a></li>
                    <li><a href="#">Cơ hội nghề nghiệp</a></li>
                </ul>
            </div>
            <div class="rs-footer-col">
                <h4>Hỗ trợ</h4>
                <ul>
                    <li><a href="#">Trung tâm trợ giúp</a></li>
                    <li><a href="#">Điều khoản</a></li>
                    <li><a href="#">Bảo mật</a></li>
                </ul>
            </div>
            <div class="rs-footer-col">
                <h4>Liên hệ</h4>
                <ul style="color: #64748B; font-size: 14px;">
                    <li style="margin-bottom: 12px;"><i class="fas fa-envelope me-2"></i> support@@unistay.com</li>
                    <li><i class="fas fa-phone-alt me-2"></i> 1800 6789</li>
                </ul>
            </div>
        </div>
        <div class="rs-footer-bottom">
            <p>© 2024 Unistay. All rights reserved.</p>
            <div class="rs-footer-lang">
                <i class="fas fa-globe"></i>
                <i class="fas fa-user-friends"></i>
            </div>
        </div>
    </div>
</footer>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Hide the default main navbar
            const mainNav = document.getElementById('mainNav');
            if (mainNav) mainNav.style.display = 'none';
        });
    </script>
}
