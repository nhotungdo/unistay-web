@{
    ViewData["Title"] = "Trang chủ - Tìm phòng lý tưởng";
    ViewData["HideDefaultLayout"] = true;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
    <style>
        /* Override body padding for this page */
        body { padding-top: 64px !important; }
    </style>
}

<!-- ============================================================
     NAVBAR (Custom for Homepage)
     ============================================================ -->
<nav class="hp-navbar" id="homeNav">
    <div class="container" style="width:100%; display:flex; align-items:center;">
        <a class="hp-nav-brand" asp-controller="Home" asp-action="Index">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
            </svg>
            Unistay
        </a>

        <ul class="hp-nav-links">
            <li><a asp-controller="Rooms" asp-action="Index">Tìm phòng</a></li>
            <li><a asp-controller="Roommates" asp-action="Index">Dịch vụ</a></li>
            <li><a asp-controller="Marketplace" asp-action="Index">Chợ đồ cũ</a></li>
            <li><a asp-controller="RentalAdvice" asp-action="Index">Blog</a></li>
        </ul>

        <div class="hp-nav-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Rooms" asp-action="Create" class="hp-btn-register">
                    + Đăng tin
                </a>
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-decoration-none gap-2"
                       data-bs-toggle="dropdown" aria-expanded="false" style="color: var(--us-text);">
                        <img src="https://ui-avatars.com/api/?name=@User.Identity.Name&background=FF5C27&color=fff&size=32"
                             style="width:32px;height:32px;border-radius:50%;" />
                        <span style="font-size:0.875rem; font-weight:600;">@User.Identity.Name</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Hồ sơ cá nhân</a></li>
                        <li><a class="dropdown-item" asp-controller="RentalAdvice" asp-action="Index">Tư vấn AI</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">Đăng xuất</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="hp-btn-login">Đăng nhập</a>
                <a asp-controller="Account" asp-action="Register" class="hp-btn-register">Đăng ký ngay</a>
            }
        </div>
    </div>
</nav>

<!-- ============================================================
     HERO SECTION
     ============================================================ -->
<section class="hp-hero">
    <div class="container">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:3rem; align-items:center;">
            <!-- Left Content -->
            <div>
                <span class="hp-hero-label">🏠 Nền tảng số 1 cho sinh viên Việt Nam</span>
                <h1>
                    Tìm phòng lý tưởng hoặc <span class="hp-orange">Đăng tin</span><br/>
                    cho thuê nhanh chóng
                </h1>
                <p>Nơi kết nối hàng triệu sinh viên với chủ trọ trên toàn Việt Nam. Minh bạch - An toàn - Hiệu quả.</p>

                <!-- Search Bar -->
                <div class="hp-search-bar">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" style="flex-shrink:0;">
                        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                    </svg>
                    <input type="text" placeholder="Nhập khu vực, quận, trường... (VD: Thủ Đức, HUTECH)">
                    <button>Tìm kiếm</button>
                </div>

                <!-- CTA Buttons -->
                <div class="hp-hero-btns">
                    <a asp-controller="Rooms" asp-action="Index" class="hp-btn-primary">
                        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5A6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                        Tìm phòng ngay
                    </a>
                    <a asp-controller="Rooms" asp-action="Create" class="hp-btn-outline-orange">
                        <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                        Đăng tin miễn phí
                    </a>
                </div>
            </div>

            <!-- Right Image/Card -->
            <div style="position:relative;">
                <div style="border-radius:20px; overflow:hidden; box-shadow: 0 16px 48px rgba(0,0,0,0.14);">
                    <img src="https://images.unsplash.com/photo-1555854877-bab0e564b8d5?w=700&h=500&fit=crop&q=80"
                         alt="Tìm phòng trọ sinh viên" style="width:100%; height:360px; object-fit:cover; display:block;">
                </div>
                <!-- Floating card -->
                <div style="position:absolute; bottom:-16px; left:-20px; background:white; border-radius:14px; padding:1rem 1.25rem; box-shadow: 0 8px 30px rgba(0,0,0,0.12); display:flex; align-items:center; gap:0.75rem;">
                    <div style="width:42px;height:42px;background:#ecfdf5;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;">✅</div>
                    <div>
                        <div style="font-size:0.8rem;font-weight:700;color:#1a1a2e;">Đã xác thực</div>
                        <div style="font-size:0.75rem;color:#6b7280;">Hơn 10.000+ phòng</div>
                    </div>
                </div>
                <!-- Floating badge -->
                <div style="position:absolute; top:-14px; right:-14px; background: var(--us-orange, #FF5C27); border-radius:12px; padding:0.7rem 1rem; box-shadow:0 8px 24px rgba(255,92,39,0.35); color:white;">
                    <div style="font-size:1.1rem;font-weight:800;">5K+</div>
                    <div style="font-size:0.72rem;opacity:0.9;">Tin đăng/tháng</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     DÀNH CHO SINH VIÊN
     ============================================================ -->
<section class="hp-student-section">
    <div class="container">
        <div style="text-align:center; margin-bottom:2rem;">
            <span class="hp-section-label">Khám phá dịch vụ</span>
            <h2 style="font-size:1.6rem; font-weight:800; color:#1a1a2e; margin-bottom:0.5rem;">Dành cho Sinh Viên</h2>
            <p style="color:#6b7280; font-size:0.9rem; max-width:500px; margin:0 auto;">Hệ sinh thái toàn diện giúp sinh viên tìm trọ, bạn ở ghép và kết nối cộng đồng dễ dàng</p>
        </div>

        <div class="hp-cards-grid">
            <!-- Card 1: Phòng mới nhất -->
            <a asp-controller="Rooms" asp-action="Index" class="hp-feature-card">
                <div class="hp-feature-icon orange">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FF5C27" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                        <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                </div>
                <h3>Phòng mới nhất</h3>
                <p>Cập nhật liên tục những phòng trọ tốt nhất, giá hợp lý dành riêng cho sinh viên trên toàn quốc.</p>
                <span class="hp-card-link">
                    Tìm ngay →
                </span>
            </a>

            <!-- Card 2: Tìm bạn ở ghép -->
            <a asp-controller="Roommates" asp-action="Index" class="hp-feature-card">
                <div class="hp-feature-icon green">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                </div>
                <h3>Tìm bạn ở ghép</h3>
                <p>Kết nối với những người bạn cùng sở thích, phù hợp lối sống để cùng chia sẻ không gian và chi phí.</p>
                <span class="hp-card-link">
                    Tìm bạn →
                </span>
            </a>

            <!-- Card 3: Hỗ trợ viên / Tư vấn AI -->
            <a asp-controller="RentalAdvice" asp-action="Index" class="hp-feature-card">
                <div class="hp-feature-icon blue">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2">
                        <circle cx="12" cy="12" r="10"/>
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>
                <h3>Hỗ trợ viên AI</h3>
                <p>Tư vấn tìm trọ thông minh bằng AI, giúp bạn chọn được phòng phù hợp nhất theo nhu cầu và ngân sách.</p>
                <span class="hp-card-link">
                    Thử ngay →
                </span>
            </a>
        </div>
    </div>
</section>

<!-- ============================================================
     BUSINESS / CHỦ TRỌ SECTION
     ============================================================ -->
<section class="hp-business">
    <div class="container">
        <div class="hp-business-inner">
            <!-- Left Image -->
            <div class="hp-business-img">
                <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=600&h=500&fit=crop&q=80"
                     alt="Chủ trọ quản lý với Unistay">
                <div style="position:absolute; bottom:24px; right:-20px; background: white; padding: 1rem 1.25rem; border-radius: 14px; box-shadow: 0 8px 30px rgba(0,0,0,0.12); min-width: 160px;">
                    <div style="font-size: 0.75rem; color:#6b7280; margin-bottom:4px;">Thu nhập tháng này</div>
                    <div style="font-size: 1.3rem; font-weight:800; color:#FF5C27;">+15.5 tr</div>
                    <div style="font-size: 0.75rem; color:#059669; font-weight:600;">▲ 12% so với tháng trước</div>
                </div>
            </div>

            <!-- Right Content -->
            <div class="hp-business-content">
                <span class="hp-section-label">Dành cho Chủ Nhà</span>
                <h2>Gia tăng thu nhập, tối ưu quản lý cùng Unistay</h2>

                <ul class="hp-check-list">
                    <li>
                        <div class="hp-check-dot">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <div>
                            <h4>Tiếp cận 10k+ sinh viên</h4>
                            <p>Tin đăng của bạn hiện thị đến hàng nghìn sinh viên đang tìm phòng mỗi ngày trên nền tảng.</p>
                        </div>
                    </li>
                    <li>
                        <div class="hp-check-dot">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <div>
                            <h4>Quản lý dễ dàng</h4>
                            <p>Theo dõi tin đăng, tương tác với khách thuê và nhận booking ngay trên ứng dụng mọi lúc mọi nơi.</p>
                        </div>
                    </li>
                    <li>
                        <div class="hp-check-dot">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                                <polyline points="20 6 9 17 4 12"/>
                            </svg>
                        </div>
                        <div>
                            <h4>Minh bạch tài chính</h4>
                            <p>Theo dõi lịch sử giao dịch, thu chi rõ ràng giúp bạn điều hành kinh doanh hiệu quả hơn.</p>
                        </div>
                    </li>
                </ul>

                <a asp-controller="Rooms" asp-action="Create" class="hp-btn-primary">
                    <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Bắt đầu kinh doanh
                </a>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     STATS BANNER
     ============================================================ -->
<section class="hp-stats">
    <div class="container">
        <div class="hp-stats-grid">
            <div class="hp-stat-item">
                <h3>10k+</h3>
                <p>Sinh viên tin tưởng sử dụng</p>
            </div>
            <div class="hp-stat-item">
                <h3>5k+</h3>
                <p>Tin đăng mỗi tháng</p>
            </div>
            <div class="hp-stat-item">
                <h3>98%</h3>
                <p>Đánh giá hài lòng</p>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     ĐÁNH GIÁ NGƯỜI DÙNG
     ============================================================ -->
<section class="hp-reviews">
    <div class="container">
        <div class="hp-reviews-header">
            <span class="hp-section-label">Phản hồi từ cộng đồng</span>
            <h2>Đánh giá từ người dùng</h2>
            <p>Hàng nghìn sinh viên và chủ trọ đã tin tưởng và sử dụng nền tảng Unistay mỗi ngày</p>
        </div>

        <div class="hp-reviews-grid">
            <!-- Review 1 -->
            <div class="hp-review-card">
                <div class="hp-stars">
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                </div>
                <p>"Tôi tìm được phòng ưng ý chỉ sau 3 ngày dùng Unistay! Giao diện rất dễ dùng, thông tin phòng chi tiết và chủ trọ phản hồi nhanh chóng. Rất hài lòng với trải nghiệm này."</p>
                <div class="hp-reviewer">
                    <div class="hp-reviewer-avatar" style="background:linear-gradient(135deg,#FF5C27,#ff8c42);">N</div>
                    <div class="hp-reviewer-info">
                        <h5>Nguyễn Văn An</h5>
                        <p>Sinh viên HUTECH · TP. HCM</p>
                    </div>
                </div>
            </div>

            <!-- Review 2 -->
            <div class="hp-review-card">
                <div class="hp-stars">
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                </div>
                <p>"Tính năng tìm bạn ở ghép quá hay! Tôi đã kết nối được với bạn cùng phòng hợp lý, cùng chia sẻ chi phí và còn trở thành bạn bè thân. Tiết kiệm được gần 2 triệu mỗi tháng."</p>
                <div class="hp-reviewer">
                    <div class="hp-reviewer-avatar" style="background:linear-gradient(135deg,#059669,#34d399);">O</div>
                    <div class="hp-reviewer-info">
                        <h5>Chi Linh</h5>
                        <p>Sinh viên UEF · Bình Thạnh</p>
                    </div>
                </div>
            </div>

            <!-- Review 3 -->
            <div class="hp-review-card">
                <div class="hp-stars">
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star">★</span>
                    <span class="hp-star" style="color:#d1d5db;">★</span>
                </div>
                <p>"Là chủ nhà, tôi đăng tin lên Unistay và chỉ vài giờ đã có sinh viên liên hệ. Hệ thống quản lý tin đăng rất chuyên nghiệp, tôi sẽ tiếp tục sử dụng cho các phòng khác."</p>
                <div class="hp-reviewer">
                    <div class="hp-reviewer-avatar" style="background:linear-gradient(135deg,#7c3aed,#a78bfa);">T</div>
                    <div class="hp-reviewer-info">
                        <h5>Trần Hương</h5>
                        <p>Chủ trọ · Quận 12</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============================================================
     TIN TỨC & BLOG
     ============================================================ -->
<section class="hp-blog">
    <div class="container">
        <div class="hp-blog-header">
            <span class="hp-section-label">Kiến thức hữu ích</span>
            <h2>Tin tức & Blog</h2>
            <p>Cập nhật những thông tin hữu ích về thị trường thuê phòng và kinh nghiệm sinh viên mỗi ngày</p>
        </div>

        <div class="hp-blog-grid">
            <!-- Blog 1 -->
            <a href="#" class="hp-blog-card">
                <img class="hp-blog-img"
                     src="https://images.unsplash.com/photo-1554995207-c18c203602cb?w=500&h=280&fit=crop&q=80"
                     alt="Blog 1">
                <div class="hp-blog-body">
                    <span class="hp-blog-tag orange">Kinh nghiệm</span>
                    <h4>5 bí quyết tìm phòng trọ an toàn và tiết kiệm cho sinh viên mới lên thành phố</h4>
                    <p>Mới lên thành phố học, chưa biết tìm phòng ở đâu? Hãy đọc ngay những kinh nghiệm quý báu này...</p>
                    <span class="hp-blog-readmore">Đọc thêm →</span>
                </div>
            </a>

            <!-- Blog 2 -->
            <a href="#" class="hp-blog-card">
                <img class="hp-blog-img"
                     src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=500&h=280&fit=crop&q=80"
                     alt="Blog 2">
                <div class="hp-blog-body">
                    <span class="hp-blog-tag green">Quản lý</span>
                    <h4>Cách sử dụng công cụ quản lý thu nhập hiệu quả dành cho chủ phòng trọ 2024</h4>
                    <p>Nắm vững những công cụ số giúp bạn tối ưu hóa doanh thu và tiết kiệm thời gian quản lý phòng...</p>
                    <span class="hp-blog-readmore">Đọc thêm →</span>
                </div>
            </a>

            <!-- Blog 3 -->
            <a href="#" class="hp-blog-card">
                <img class="hp-blog-img"
                     src="https://images.unsplash.com/photo-1486325212027-8081e485255e?w=500&h=280&fit=crop&q=80"
                     alt="Blog 3">
                <div class="hp-blog-body">
                    <span class="hp-blog-tag blue">Thị trường</span>
                    <h4>Xu hướng thị trường cho thuê phòng trọ năm 2024: Thách thức và cơ hội</h4>
                    <p>Phân tích chuyên sâu về tình hình thị trường cho thuê phòng trọ dành cho sinh viên năm nay...</p>
                    <span class="hp-blog-readmore">Đọc thêm →</span>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ============================================================
     FOOTER (New Design)
     ============================================================ -->
<footer class="hp-footer">
    <div class="container">
        <div class="hp-footer-grid">
            <!-- Col 1: Brand -->
            <div class="hp-footer-col">
                <a class="hp-footer-brand" asp-controller="Home" asp-action="Index">
                    <svg width="20" height="20" fill="#FF5C27" viewBox="0 0 24 24">
                        <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                    </svg>
                    <span>Uni</span><span style="color:white;">stay</span>
                </a>
                <p>Nền tảng kết nối sinh viên với chủ trọ uy tín tại Việt Nam. Minh bạch - An toàn - Hiệu quả.</p>
                <div class="hp-footer-social">
                    <a href="#" class="hp-social-btn" title="Facebook">f</a>
                    <a href="#" class="hp-social-btn" title="Zalo">Z</a>
                    <a href="#" class="hp-social-btn" title="TikTok">T</a>
                    <a href="#" class="hp-social-btn" title="YouTube">▶</a>
                </div>
            </div>

            <!-- Col 2: Về Unistay -->
            <div class="hp-footer-col">
                <h4>Về Unistay</h4>
                <ul class="hp-footer-links">
                    <li><a href="#">Giới thiệu</a></li>
                    <li><a href="#">Nhà đầu tư</a></li>
                    <li><a href="#">Tuyển dụng</a></li>
                    <li><a href="#">Blog</a></li>
                </ul>
            </div>

            <!-- Col 3: Hỗ trợ khách hàng -->
            <div class="hp-footer-col">
                <h4>Hỗ trợ khách hàng</h4>
                <ul class="hp-footer-links">
                    <li><a href="#">Tìm kiếm phòng</a></li>
                    <li><a href="#">Đăng tin cho thuê</a></li>
                    <li><a href="#">Tìm bạn ở ghép</a></li>
                    <li><a href="#">Chợ đồ cũ</a></li>
                    <li><a href="#">Trung tâm trợ giúp</a></li>
                </ul>
            </div>

            <!-- Col 4: Liên hệ -->
            <div class="hp-footer-col">
                <h4>Liên hệ</h4>
                <ul class="hp-footer-contact">
                    <li>
