@{
    ViewData["Title"] = "Chọn Hành Trình Của Bạn - UniStay";
    Layout = null; // Clean slate for premium feel
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <link rel="stylesheet" href="~/css/onboarding.css" asp-append-version="true" />
</head>
<body>
    <div class="ob-wrapper">
        <div class="ob-container">
            <div class="ob-header">
                <span class="ob-badge">Chào mừng bạn mới</span>
                <h1 class="ob-title">Hành trình của bạn<br>Bắt đầu từ đây</h1>
                <p class="ob-subtitle">Để mang lại những gợi ý chính xác nhất, hãy cho Unistay biết mục tiêu chính của bạn hiện tại là gì.</p>
            </div>

            <div class="ob-role-grid">
                <!-- Seeker Role -->
                <div class="ob-role-card" id="card-student" onclick="selectRole('Student', this)">
                    <div class="ob-check"><i class="fas fa-check"></i></div>
                    <div class="ob-role-icon-box blue-box">
                        <i class="fas fa-search-location"></i>
                    </div>
                    <h3 class="ob-role-title">Tôi tìm nơi ở</h3>
                    <p class="ob-role-desc">Khám phá hàng ngàn phòng trọ, căn hộ và tìm kiếm những người bạn cùng phòng lý tưởng nhất.</p>
                    <div style="font-size: 11px; font-weight: 800; color: #2563EB; text-transform: uppercase; letter-spacing: 1px;">
                        Tiếp cận 50k+ lựa chọn
                    </div>
                </div>

                <!-- Landlord Role -->
                <div class="ob-role-card" id="card-landlord" onclick="selectRole('Landlord', this)">
                    <div class="ob-check"><i class="fas fa-check"></i></div>
                    <div class="ob-role-icon-box orange-box">
                        <i class="fas fa-home"></i>
                    </div>
                    <h3 class="ob-role-title">Tôi đăng tin cho thuê</h3>
                    <p class="ob-role-desc">Tiếp cận cộng đồng sinh viên văn minh, quản lý tin đăng dễ dàng và gia tăng tỷ lệ lấp phòng.</p>
                    <div style="font-size: 11px; font-weight: 800; color: #EA580C; text-transform: uppercase; letter-spacing: 1px;">
                        Quản lý chuyên nghiệp
                    </div>
                </div>
            </div>

            <div class="ob-footer-note">
                Bạn có thể thay đổi vai trò này bất cứ lúc nào trong <a href="#">Cài đặt tài khoản</a>.
            </div>
        </div>
    </div>

    <form id="roleForm" asp-action="SelectRole" method="post" style="display: none;">
        <input type="hidden" name="role" id="selectedRole" />
    </form>

    <script>
        function selectRole(role, element) {
            // Remove active class from all
            document.querySelectorAll('.ob-role-card').forEach(el => el.classList.remove('active'));
            
            // Add to selected
            element.classList.add('active');
            
            // Set value and submit
            document.getElementById('selectedRole').value = role;
            
            // Animation delay
            setTimeout(() => {
                document.getElementById('roleForm').submit();
            }, 600);
        }
    </script>
</body>
</html>
