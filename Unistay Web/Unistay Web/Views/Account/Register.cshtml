@model Unistay_Web.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Tạo tài khoản mới - Unistay";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    
    <!-- Styles -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>
<body>
    <div class="auth-wrapper">
        <!-- ===== LEFT SIDE (Visual) ===== -->
        <div class="auth-left" style="background-image: url('https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?w=1200&q=80')">
            <div class="auth-left-content">
                <div class="auth-logo">
                    <div class="auth-logo-icon">
                        <i class="fas fa-building" style="color: white;"></i>
                    </div>
                    <span class="auth-logo-text">Unistay</span>
                </div>
                <h1 class="auth-left-title">
                    Tìm kiếm không gian sống lý tưởng cho hành trình đại học.
                </h1>
                <p class="auth-left-desc">
                    Gia nhập cộng đồng hơn 10,000 sinh viên và chủ trọ trên khắp cả nước.
                </p>
            </div>
        </div>

        <!-- ===== RIGHT SIDE (Form) ===== -->
        <div class="auth-right">
            <div class="auth-form-container" style="max-height: 95vh; overflow-y: auto; padding-right: 10px;">
                <div class="auth-header">
                    <h2>Tạo tài khoản mới</h2>
                    <p>Khám phá ngay những tiện ích dành riêng cho bạn</p>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div style="background: #FEF2F2; border: 1px solid #FCA5A5; color: #991B1B; padding: 12px; border-radius: 8px; margin-bottom: 20px; font-size: 14px;">
                        <div asp-validation-summary="All"></div>
                    </div>
                }

                <div class="role-selector">
                    <button type="button" class="role-btn active" onclick="setRole('Student')">Tôi là Sinh viên</button>
                    <button type="button" class="role-btn" onclick="setRole('Host')">Tôi là Chủ trọ</button>
                </div>

                <form asp-action="Register" asp-controller="Account" method="post">
                    <!-- Hidden field for role if needed by model -->
                    @* <input type="hidden" asp-for="Role" id="roleInput" value="Student" /> *@

                    <!-- Full Name -->
                    <div class="form-group">
                        <label asp-for="FullName" class="form-label">Họ và tên</label>
                        <div class="input-wrapper">
                            <i class="far fa-user input-icon"></i>
                            <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                        </div>
                        <span asp-validation-for="FullName" style="color: #ef4444; font-size: 13px; margin-top: 4px; display: block;"></span>
                    </div>

                    <!-- Email -->
                    <div class="form-group">
                        <label asp-for="Email" class="form-label">Email</label>
                        <div class="input-wrapper">
                            <i class="far fa-envelope input-icon"></i>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                        </div>
                        <span asp-validation-for="Email" style="color: #ef4444; font-size: 13px; margin-top: 4px; display: block;"></span>
                    </div>

                    <!-- Phone -->
                    <div class="form-group">
                        <label asp-for="Phone" class="form-label">Số điện thoại</label>
                        <div class="input-wrapper">
                            <i class="fas fa-phone-alt input-icon"></i>
                            <input asp-for="Phone" class="form-control" placeholder="0901 234 567" />
                        </div>
                        <span asp-validation-for="Phone" style="color: #ef4444; font-size: 13px; margin-top: 4px; display: block;"></span>
                    </div>

                    <!-- Passwords Grid -->
                    <div class="form-grid">
                        <div class="form-group">
                            <label asp-for="Password" class="form-label">Mật khẩu</label>
                            <div class="input-wrapper">
                                <i class="fas fa-lock input-icon"></i>
                                <input asp-for="Password" type="password" class="form-control" placeholder="........" />
                            </div>
                            <span asp-validation-for="Password" style="color: #ef4444; font-size: 13px; margin-top: 4px; display: block;"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="ConfirmPassword" class="form-label">Xác nhận</label>
                            <div class="input-wrapper">
                                <i class="fas fa-shield-alt input-icon"></i>
                                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="........" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" style="color: #ef4444; font-size: 13px; margin-top: 4px; display: block;"></span>
                        </div>
                    </div>

                    <!-- Agreement -->
                    <div class="form-check">
                        <input type="checkbox" class="form-check-input" id="terms" required />
                        <label class="form-check-label" for="terms" style="font-size: 12px; line-height: 1.4;">
                            Bằng cách đăng ký, bạn đồng ý với <a href="#" style="color: #2563EB; text-decoration: none; font-weight: 600;">Điều khoản dịch vụ</a> và <a href="#" style="color: #2563EB; text-decoration: none; font-weight: 600;">Chính sách bảo mật</a> của Unistay.
                        </label>
                    </div>

                    <!-- Submit -->
                    <button type="submit" class="btn-login">
                        Đăng ký ngay <i class="fas fa-arrow-right"></i>
                    </button>
                </form>

                <div class="auth-footer" style="margin: 24px 0;">
                    Đã có tài khoản? <a asp-action="Login">Đăng nhập</a>
                </div>

                <div class="auth-divider">
                    <span>HOẶC ĐĂNG KÝ BẰNG</span>
                </div>

                <!-- Social login -->
                <div class="social-buttons" style="grid-template-columns: 1fr 1fr; margin-bottom: 20px;">
                    <a asp-action="GoogleLogin" asp-controller="Account" class="btn-social" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
                        <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg" alt="Google">
                        Google
                    </a>
                    <a href="#" class="btn-social" style="background-color: #F8FAFC; border: 1px solid #E2E8F0;">
                        <i class="fab fa-facebook" style="color: #1877F2;"></i>
                        Facebook
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    
    <script>
        function setRole(role) {
            document.querySelectorAll('.role-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            // Update hidden input if needed: document.getElementById('roleInput').value = role;
        }
    </script>
</body>
</html>
