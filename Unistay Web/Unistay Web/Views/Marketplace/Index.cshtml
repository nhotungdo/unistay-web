@section Scripts {
<script>
    // FAQ accordion
    document.querySelectorAll('.pk-faq-toggle').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var item = this.closest('.pk-faq-item');
            var isOpen = item.classList.contains('open');
            document.querySelectorAll('.pk-faq-item').forEach(function(i) { i.classList.remove('open'); });
            if (!isOpen) item.classList.add('open');
        });
    });
</script>
}
